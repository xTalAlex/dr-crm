---
import { Image } from "astro:assets";
import "@/styles/global.css";
import heroImg from "@/assets/images/hero.jpg";
import content from "@/data/content.json";

export const prerender = false;

const { doctor, studio, services, contacts, seo } = content;
const user = Astro.locals.user;
---

<html lang="it">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="viewport" content="width=device-width" />
    <meta name="description" content={seo.description} />
    <title>{seo.title}</title>
  </head>
  <body class="bg-navy-950 text-white font-sans antialiased">
    <!-- Nav -->
    <nav
      class="fixed top-0 w-full z-50 bg-navy-950/80 backdrop-blur-md border-b border-gold-400/10"
    >
      <div
        class="max-w-6xl mx-auto px-6 py-4 flex items-center justify-between"
      >
        <span class="font-serif text-gold-400 text-lg tracking-wide"
          >Dr. {doctor.lastName}</span
        >
        <div class="flex items-center gap-6 text-sm">
          <a
            href="#servizi"
            class="text-gray-400 hover:text-gold-400 transition-colors"
            >Servizi</a
          >
          <a
            href="#contatti"
            class="text-gray-400 hover:text-gold-400 transition-colors"
            >Contatti</a
          >
          {
            user?.role === "admin" ? (
              <a
                href="/admin"
                class="text-xs bg-gold-400/10 text-gold-400 px-3 py-1.5 rounded-full border border-gold-400/20 hover:bg-gold-400/20 transition-colors"
              >
                Admin
              </a>
            ) : (
              <a
                href="/login"
                class="text-xs text-gray-500 hover:text-gray-400 transition-colors"
              >
                Login
              </a>
            )
          }
        </div>
      </div>
    </nav>

    <!-- Hero -->
    <header
      class="relative min-h-screen flex items-center justify-center overflow-hidden pt-20"
    >
      <!-- Decorative background -->
      <div class="absolute inset-0">
        <div
          class="absolute top-1/4 left-1/4 w-96 h-96 bg-gold-400/5 rounded-full blur-3xl"
        >
        </div>
        <div
          class="absolute bottom-1/4 right-1/4 w-80 h-80 bg-gold-400/3 rounded-full blur-3xl"
        >
        </div>
        <div
          class="absolute top-0 left-0 w-full h-full bg-[radial-gradient(ellipse_at_top,rgba(184,148,62,0.06),transparent_60%)]"
        >
        </div>
      </div>

      <div class="relative text-center px-6 max-w-3xl">
        <div class="inline-block mb-8">
          <span
            class="text-gold-400/60 text-xs tracking-[0.3em] uppercase font-medium"
            >{studio.name} · {studio.since}</span
          >
          <div
            class="mt-1 h-px w-16 mx-auto bg-gradient-to-r from-transparent via-gold-400/40 to-transparent"
          >
          </div>
        </div>

        <h1
          class="font-serif text-5xl md:text-7xl font-medium text-white leading-tight tracking-tight"
        >
          {doctor.title}
          {doctor.firstName}<br />
          <span class="text-gold-400">{doctor.lastName}</span>
        </h1>

        <div
          class="mt-6 flex items-center justify-center gap-3 text-gray-400 text-sm tracking-wide"
        >
          {
            doctor.roles.map((role: string, i: number) => (
              <>
                {i > 0 && <span class="w-1 h-1 rounded-full bg-gold-400/40" />}
                <span>{role}</span>
              </>
            ))
          }
        </div>

        <div class="mt-8 text-gold-400/70 font-serif text-lg tracking-wide">
          ✦ {studio.badge} ✦
        </div>

        <div class="mt-10 mb-20">
          <a
            href={`tel:${contacts.phone.href}`}
            class="group inline-flex items-center gap-3 bg-gold-400/10 hover:bg-gold-400/15 border border-gold-400/20 hover:border-gold-400/40 text-gold-400 px-8 py-3.5 rounded-full transition-all duration-300"
          >
            <span class="text-sm font-medium tracking-wide">{studio.cta}</span>
            <svg
              xmlns="http://www.w3.org/2000/svg"
              class="w-4 h-4 group-hover:translate-x-0.5 transition-transform"
              fill="none"
              viewBox="0 0 24 24"
              stroke="currentColor"
              stroke-width="2"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                d="M17 8l4 4m0 0l-4 4m4-4H3"></path>
            </svg>
          </a>
        </div>
      </div>

      <div class="absolute bottom-8 left-1/2 -translate-x-1/2 animate-bounce">
        <svg
          xmlns="http://www.w3.org/2000/svg"
          class="w-5 h-5 mx-auto text-gold-400/30"
          fill="none"
          viewBox="0 0 24 24"
          stroke="currentColor"
          stroke-width="2"
        >
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            d="M19 14l-7 7m0 0l-7-7m7 7V3"></path>
        </svg>
      </div>
    </header>

    <!-- Services -->
    <section id="servizi" class="py-24">
      <div class="max-w-6xl mx-auto px-6">
        <div class="grid grid-cols-1 md:grid-cols-2 gap-16 items-start">
          <div>
            <span
              class="text-gold-400/60 text-xs tracking-[0.3em] uppercase font-medium"
              >Servizi</span
            >
            <h2 class="mt-4 font-serif text-3xl md:text-4xl text-white">
              I Nostri Servizi
            </h2>
            <div
              class="mt-4 h-px w-24 bg-gradient-to-r from-gold-400/30 to-transparent"
            >
            </div>

            <div class="relative mt-10">
              <div
                class="absolute -inset-3 bg-gold-400/10 rounded-2xl blur-2xl"
              >
              </div>
              <Image
                src={heroImg}
                alt="Studio Dentistico"
                class="relative rounded-2xl border border-white/10 shadow-xl object-cover w-full aspect-[4/3]"
                widths={[400, 800]}
                sizes="(max-width: 768px) 100vw, 50vw"
              />
            </div>
          </div>

          <div class="space-y-3">
            {
              services.map((service, i) => (
                <div class="group flex items-center gap-5 py-4 px-5 rounded-xl hover:bg-white/5 transition-colors cursor-default">
                  <span class="text-gold-400/40 font-serif text-sm tabular-nums">
                    {String(i + 1).padStart(2, "0")}
                  </span>
                  <span class="h-px flex-1 bg-white/5 group-hover:bg-gold-400/20 transition-colors" />
                  <h3 class="font-medium text-white group-hover:text-gold-400 transition-colors">
                    {service}
                  </h3>
                </div>
              ))
            }
          </div>
        </div>
      </div>
    </section>

    <!-- Contact -->
    <section id="contatti" class="py-24">
      <div class="max-w-6xl mx-auto px-6">
        <div class="text-center mb-16">
          <span
            class="text-gold-400/60 text-xs tracking-[0.3em] uppercase font-medium"
            >Contatti</span
          >
          <h2 class="mt-4 font-serif text-3xl md:text-4xl text-white">
            Contatti
          </h2>
          <div
            class="mt-4 h-px w-24 mx-auto bg-gradient-to-r from-transparent via-gold-400/30 to-transparent"
          >
          </div>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-3 gap-6 max-w-4xl mx-auto">
          <!-- Phone -->
          <a
            href={`tel:${contacts.phone.href}`}
            class="group bg-navy-900/50 border border-white/5 hover:border-gold-400/20 rounded-xl p-8 text-center transition-all duration-300"
          >
            <div
              class="w-12 h-12 mx-auto mb-4 rounded-full bg-gold-400/10 flex items-center justify-center"
            >
              <svg
                xmlns="http://www.w3.org/2000/svg"
                class="w-5 h-5 text-gold-400"
                fill="none"
                viewBox="0 0 24 24"
                stroke="currentColor"
                stroke-width="2"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"
                ></path>
              </svg>
            </div>
            <p class="text-xs text-gray-500 uppercase tracking-wider mb-2">
              Telefono
            </p>
            <p
              class="text-white group-hover:text-gold-400 font-medium transition-colors"
            >
              {contacts.phone.display}
            </p>
            <p class="text-gray-500 text-xs mt-2">{contacts.phone.note}</p>
          </a>

          <!-- Email -->
          <a
            href={`mailto:${contacts.email}`}
            class="group bg-navy-900/50 border border-white/5 hover:border-gold-400/20 rounded-xl p-8 text-center transition-all duration-300"
          >
            <div
              class="w-12 h-12 mx-auto mb-4 rounded-full bg-gold-400/10 flex items-center justify-center"
            >
              <svg
                xmlns="http://www.w3.org/2000/svg"
                class="w-5 h-5 text-gold-400"
                fill="none"
                viewBox="0 0 24 24"
                stroke="currentColor"
                stroke-width="2"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"
                ></path>
              </svg>
            </div>
            <p class="text-xs text-gray-500 uppercase tracking-wider mb-2">
              Email
            </p>
            <p
              class="text-white group-hover:text-gold-400 font-medium transition-colors text-sm"
            >
              {contacts.email}
            </p>
          </a>

          <!-- Address -->
          <a
            href={`https://maps.google.com/?q=${encodeURIComponent(contacts.address.street + " " + contacts.address.city)}`}
            target="_blank"
            rel="noopener noreferrer"
            class="group bg-navy-900/50 border border-white/5 hover:border-gold-400/20 rounded-xl p-8 text-center transition-all duration-300"
          >
            <div
              class="w-12 h-12 mx-auto mb-4 rounded-full bg-gold-400/10 flex items-center justify-center"
            >
              <svg
                xmlns="http://www.w3.org/2000/svg"
                class="w-5 h-5 text-gold-400"
                fill="none"
                viewBox="0 0 24 24"
                stroke="currentColor"
                stroke-width="2"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"
                ></path>
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"></path>
              </svg>
            </div>
            <p class="text-xs text-gray-500 uppercase tracking-wider mb-2">
              Indirizzo
            </p>
            <p
              class="text-white group-hover:text-gold-400 font-medium transition-colors"
            >
              {contacts.address.street}
            </p>
            <p class="text-gray-500 text-sm">{contacts.address.city}</p>
          </a>
        </div>

        <div class="mt-12 text-center">
          <p class="text-gray-500 text-sm italic">{studio.note}</p>
        </div>
      </div>
    </section>

    <!-- Footer -->
    <footer class="border-t border-white/5 py-10">
      <div class="max-w-6xl mx-auto px-6 text-center">
        <p class="font-serif text-gold-400/40 text-sm">
          {doctor.title}
          {doctor.firstName}
          {doctor.lastName}
        </p>
        <p class="text-gray-600 text-xs mt-2">
          {doctor.roles.join(" — ")} — {contacts.address.city}
        </p>
        <p class="text-gray-700 text-xs mt-4">
          &copy; {new Date().getFullYear()}
        </p>
      </div>
    </footer>
  </body>
</html>
