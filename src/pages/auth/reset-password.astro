---
import BaseLayout from "@/layouts/BaseLayout.astro";
import Button from "@/components/Button.astro";
import CenteredHeader from "@/components/CenteredHeader.astro";
import FormField from "@/components/FormField.astro";
import Link from "@/components/Link.astro";
import { Icon } from "astro-icon/components";

export const prerender = false;
---

<BaseLayout
  title="Reset Password"
  bodyClass="min-h-screen flex items-center justify-center"
  noindex
>
  <div class="w-full max-w-sm px-6" x-data="resetPage()">
    <CenteredHeader
      x-text="hasToken ? 'Nuova password' : 'Recupera password'"
    />

    <!-- Request reset form (no token) -->
    <form
      x-show="!hasToken"
      x-on:submit.prevent="submitRequest"
      class="space-y-5"
    >
      <FormField label="Email" type="email" x-model="email" />

      <template x-if="error">
        <p class="text-red-500 text-sm" x-text="error"></p>
      </template>

      <template x-if="success">
        <p class="text-green-600 text-sm" x-text="success"></p>
      </template>

      <Button variant="primary" fullWidth type="submit" x-bind:disabled="loading">
        <span x-show="!loading">Invia link di reset</span>
        <span x-show="loading" x-cloak>Invio in corso...</span>
      </Button>
    </form>

    <!-- Set new password form (with token) -->
    <form
      x-show="hasToken"
      x-cloak
      x-on:submit.prevent="submitNewPassword"
      class="space-y-5"
    >
      <FormField label="Nuova password" type="password" x-model="password" minlength="8" />
      <FormField label="Conferma password" type="password" x-model="confirm" minlength="8" />

      <template x-if="error">
        <p class="text-red-500 text-sm" x-text="error"></p>
      </template>

      <template x-if="success">
        <p class="text-green-600 text-sm" x-text="success"></p>
      </template>

      <Button variant="primary" fullWidth type="submit" x-bind:disabled="loading">
        <span x-show="!loading">Salva password</span>
        <span x-show="loading" x-cloak>Salvataggio...</span>
      </Button>
    </form>

    <div class="mt-8 text-center">
      <Link variant="muted" href="/auth/login" class="text-xs inline-flex items-center gap-1">
        <Icon name="material-symbols-light:arrow-back" class="size-3.5" />
        Torna al login
      </Link>
    </div>
  </div>

  <script>
    import Alpine from "alpinejs";
    import resetPasswordPage from "@/alpine/resetPasswordPage";

    document.addEventListener("alpine:init", () => {
      resetPasswordPage(Alpine);
    });
  </script>
</BaseLayout>
