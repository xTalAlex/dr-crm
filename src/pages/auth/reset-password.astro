---
import BaseLayout from "@/layouts/BaseLayout.astro";
import content from "@/data/content.json";

export const prerender = false;

const { doctor } = content;
---

<BaseLayout
  title="Reset Password"
  bodyClass="bg-gray-50 text-slate-800 font-sans antialiased min-h-screen flex items-center justify-center"
  noindex
>
  <div class="w-full max-w-sm px-6" x-data="resetPage()">
    <div class="text-center mb-10">
      <a href="/" class="font-serif text-petrol-700 text-2xl tracking-wide"
        >{doctor.title} {doctor.lastName}</a
      >
      <p
        class="text-gray-400 text-sm mt-2"
        x-text="hasToken ? 'Nuova password' : 'Recupera password'"
      >
      </p>
    </div>

    <!-- Request reset form (no token) -->
    <form
      x-show="!hasToken"
      x-on:submit.prevent="submitRequest"
      class="space-y-5"
    >
      <div>
        <label
          for="email"
          class="block text-xs text-gray-400 uppercase tracking-wider mb-2"
          >Email</label
        >
        <input
          id="email"
          type="email"
          x-model="email"
          required
          class="w-full bg-gray-50 border border-gray-200 focus:border-petrol-400 rounded-lg px-4 py-3 text-slate-800 text-sm outline-none transition-colors"
        />
      </div>

      <template x-if="error">
        <p class="text-red-500 text-sm" x-text="error"></p>
      </template>

      <template x-if="success">
        <p class="text-green-600 text-sm" x-text="success"></p>
      </template>

      <button
        type="submit"
        :disabled="loading"
        class="w-full bg-petrol-600 hover:bg-petrol-700 text-white py-3 rounded-lg text-sm font-medium tracking-wide transition-all duration-300 disabled:opacity-50"
      >
        <span x-show="!loading">Invia link di reset</span>
        <span x-show="loading" x-cloak>Invio in corso...</span>
      </button>
    </form>

    <!-- Set new password form (with token) -->
    <form
      x-show="hasToken"
      x-cloak
      x-on:submit.prevent="submitNewPassword"
      class="space-y-5"
    >
      <div>
        <label
          for="password"
          class="block text-xs text-gray-400 uppercase tracking-wider mb-2"
          >Nuova password</label
        >
        <input
          id="password"
          type="password"
          x-model="password"
          required
          minlength="8"
          class="w-full bg-gray-50 border border-gray-200 focus:border-petrol-400 rounded-lg px-4 py-3 text-slate-800 text-sm outline-none transition-colors"
        />
      </div>

      <div>
        <label
          for="confirm"
          class="block text-xs text-gray-400 uppercase tracking-wider mb-2"
          >Conferma password</label
        >
        <input
          id="confirm"
          type="password"
          x-model="confirm"
          required
          minlength="8"
          class="w-full bg-gray-50 border border-gray-200 focus:border-petrol-400 rounded-lg px-4 py-3 text-slate-800 text-sm outline-none transition-colors"
        />
      </div>

      <template x-if="error">
        <p class="text-red-500 text-sm" x-text="error"></p>
      </template>

      <template x-if="success">
        <p class="text-green-600 text-sm" x-text="success"></p>
      </template>

      <button
        type="submit"
        :disabled="loading"
        class="w-full bg-petrol-600 hover:bg-petrol-700 text-white py-3 rounded-lg text-sm font-medium tracking-wide transition-all duration-300 disabled:opacity-50"
      >
        <span x-show="!loading">Salva password</span>
        <span x-show="loading" x-cloak>Salvataggio...</span>
      </button>
    </form>

    <div class="mt-8 text-center">
      <a
        href="/auth/login"
        class="text-gray-400 text-xs hover:text-petrol-700 transition-colors"
        >&larr; Torna al login</a
      >
    </div>
  </div>

  <script>
    import Alpine from "alpinejs";
    import resetPage from "@/alpine/resetPage";

    document.addEventListener("alpine:init", () => {
      resetPage(Alpine);
    });
  </script>
</BaseLayout>
