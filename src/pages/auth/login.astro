---
import BaseLayout from "@/layouts/BaseLayout.astro";
import CenteredHeader from "@/components/CenteredHeader.astro";
import Button from "@/components/Button.astro";
import FormField from "@/components/FormField.astro";
import Link from "@/components/Link.astro";
import { Icon } from "astro-icon/components";

export const prerender = false;
const user = Astro.locals.user;
if (user?.role === "admin") return Astro.redirect("/admin");
---

<BaseLayout
  title="Login"
  bodyClass="min-h-screen flex items-center justify-center"
  noindex
>
  <div class="w-full max-w-sm px-6" x-data="loginForm">
    <CenteredHeader subtitle="Accesso riservato" />

    <form x-on:submit.prevent="submitLogin" class="space-y-5">
      <FormField label="Email" type="email" x-model="email" />
      <FormField label="Password" type="password" x-model="password" />

      <template x-if="error">
        <p class="text-red-500 text-sm" x-text="error"></p>
      </template>

      <Button
        variant="primary"
        fullWidth
        type="submit"
        x-bind:disabled="loading"
      >
        <span x-show="!loading">Accedi</span>
        <span x-show="loading" x-cloak>Accesso in corso...</span>
      </Button>

      <div class="text-center">
        <Link variant="muted" href="/auth/reset-password" class="text-xs">
          Password dimenticata?
        </Link>
      </div>
    </form>

    <div class="mt-8 text-center">
      <Link
        variant="muted"
        href="/"
        class="text-xs inline-flex items-center gap-1"
      >
        <Icon name="material-symbols-light:arrow-back" class="size-3.5" />
        Torna al sito
      </Link>
    </div>
  </div>

  <script>
    import Alpine from "alpinejs";
    import loginPage from "@/alpine/loginPage";

    document.addEventListener("alpine:init", () => {
      loginPage(Alpine);
    });
  </script>
</BaseLayout>
