---
import BaseLayout from "@/layouts/BaseLayout.astro";
import Link from "@/components/Link.astro";
import Wordmark from "@/components/Wordmark.astro";

export const prerender = false;
const user = Astro.locals.user;
if (user?.role === "admin") return Astro.redirect("/admin");
---

<BaseLayout
  title="Login"
  bodyClass="min-h-screen flex items-center justify-center"
  noindex
>
  <div class="w-full max-w-sm px-6" x-data="loginForm">
    <div class="text-center mb-10">
      <a href="/">
        <Wordmark class="text-2xl" />
      </a>
      <p class="text-neutral-500 text-sm mt-2">Accesso riservato</p>
    </div>

    <form x-on:submit.prevent="submitLogin" class="space-y-5">
      <div>
        <label
          for="email"
          class="block text-xs text-neutral-500 uppercase tracking-wider mb-2"
          >Email</label
        >
        <input
          id="email"
          type="email"
          x-model="email"
          required
          class="w-full bg-neutral-50 border border-neutral-200 focus:border-petrol-400 rounded-lg px-4 py-3 text-neutral-900 text-sm outline-none transition-colors"
        />
      </div>

      <div>
        <label
          for="password"
          class="block text-xs text-neutral-500 uppercase tracking-wider mb-2"
          >Password</label
        >
        <input
          id="password"
          type="password"
          x-model="password"
          required
          class="w-full bg-neutral-50 border border-neutral-200 focus:border-petrol-400 rounded-lg px-4 py-3 text-neutral-900 text-sm outline-none transition-colors"
        />
      </div>

      <template x-if="error">
        <p class="text-red-500 text-sm" x-text="error"></p>
      </template>

      <button
        type="submit"
        :disabled="loading"
        class="w-full bg-petrol-600 hover:bg-petrol-700 text-neutral-50 py-3 rounded-lg text-sm font-medium tracking-wide transition-all duration-300 disabled:opacity-50"
      >
        <span x-show="!loading">Accedi</span>
        <span x-show="loading" x-cloak>Accesso in corso...</span>
      </button>

      <div class="text-center">
        <Link
          variant="muted"
          href="/auth/reset-password"
          class="text-xs"
        >
          Password dimenticata?
        </Link>
      </div>
    </form>

    <div class="mt-8 text-center">
      <Link variant="muted" href="/" class="text-xs">&larr; Torna al sito</Link>
    </div>
  </div>

  <script>
    import Alpine from "alpinejs";
    import loginPage from "@/alpine/loginPage";

    document.addEventListener("alpine:init", () => {
      loginPage(Alpine);
    });
  </script>
</BaseLayout>
