---
import BaseLayout from "@/layouts/BaseLayout.astro";
import content from "@/data/content.json";

export const prerender = false;

const { token } = Astro.params;
const { doctor } = content;
---

<BaseLayout title="Documenti Condivisi" noindex>
  <div
    class="min-h-screen flex items-center justify-center p-4"
    x-data={`magicFiles('${token}')`}
  >
    <div class="w-full max-w-lg">
      <div class="text-center mb-8">
        <p class="font-serif text-petrol-700 text-lg">
          {doctor.title}
          {doctor.lastName}
        </p>
        <p class="text-gray-400 text-sm mt-1">Documenti condivisi</p>
      </div>

      <div class="bg-white border border-gray-200 rounded-xl p-6 shadow-sm">
        <!-- PIN form -->
        <template x-if="!data && !loading">
          <form x-on:submit.prevent="verify()" class="space-y-4">
            <p class="text-sm text-slate-800 text-center">
              Inserisci il codice PIN per accedere ai documenti
            </p>
            <div class="flex justify-center">
              <input
                type="text"
                x-model="pin"
                x-ref="pinField"
                inputmode="numeric"
                maxlength="4"
                pattern="[0-9]{4}"
                required
                placeholder="••••"
                class="w-32 text-center text-2xl font-mono tracking-[0.5em] bg-gray-50 border border-gray-200 focus:border-petrol-400 rounded-lg px-3 py-3 text-slate-800 outline-none transition-colors"
              />
            </div>
            <template x-if="error">
              <p class="text-center text-red-500 text-sm" x-text="error"></p>
            </template>
            <div class="flex justify-center">
              <button
                type="submit"
                :disabled="loading"
                class="px-6 py-2.5 bg-petrol-600 hover:bg-petrol-700 text-white rounded-lg text-sm font-medium transition-all duration-300 disabled:opacity-50"
              >
                <span x-show="!loading">Accedi</span>
                <span x-show="loading" x-cloak>Verifica...</span>
              </button>
            </div>
          </form>
        </template>

        <!-- Loading -->
        <template x-if="loading">
          <p class="text-center text-gray-400 py-4">Caricamento...</p>
        </template>

        <template x-if="data">
          <div>
            <h2
              class="text-lg font-serif text-slate-800 mb-1"
              x-text="data.label || 'Documenti'"
            >
            </h2>
            <p class="text-xs text-gray-400 mb-6">
              Scade il <span
                x-text="new Date(data.expiresAt).toLocaleDateString('it-IT')"
              ></span>
            </p>
            <ul class="space-y-2">
              <template x-for="f in data.files" :key="f.fileName">
                <li
                  class="flex items-center justify-between p-3 bg-gray-50 rounded-lg border border-gray-100"
                >
                  <div class="min-w-0 flex-1">
                    <p
                      class="text-sm text-slate-800 truncate"
                      x-text="f.fileName"
                    >
                    </p>
                    <p
                      class="text-xs text-gray-400"
                      x-text="(f.size / 1024).toFixed(0) + ' KB'"
                    >
                    </p>
                  </div>
                  <a
                    :href="f.url"
                    target="_blank"
                    rel="noopener noreferrer"
                    class="ml-3 px-3 py-1.5 bg-petrol-600 hover:bg-petrol-700 text-white text-xs rounded-lg transition-colors"
                    >Scarica</a
                  >
                </li>
              </template>
            </ul>
          </div>
        </template>
      </div>
    </div>
  </div>

  <script>
    import Alpine from "alpinejs";
    import magicFilesPage from "@/alpine/magicFilesPage";

    document.addEventListener("alpine:init", () => {
      magicFilesPage(Alpine);
    });
  </script>
</BaseLayout>
