---
import BaseLayout from "@/layouts/BaseLayout.astro";
import PinForm from "@/components/shared-files/PinForm.astro";
import FileList from "@/components/shared-files/FileList.astro";
import content from "@/data/content.json";

export const prerender = false;

const { token } = Astro.params;
const { doctor } = content;
---

<BaseLayout title="Documenti Condivisi" noindex>
  <div
    class="min-h-screen flex justify-center pt-16 sm:pt-0 sm:items-center p-4"
    x-data={`magicFiles('${token}')`}
  >
    <div class="w-full max-w-lg">
      <div class="text-center mb-8">
        <p class="font-serif text-petrol-500 text-lg">
          {doctor.title}
          {doctor.lastName}
        </p>
        <p class="text-neutral-500 text-sm mt-1">Documenti condivisi</p>
      </div>

      <div
        class="bg-neutral-50 border border-neutral-200 rounded-xl p-6 shadow-sm"
      >
        <template x-if="!data && !loading">
          <PinForm />
        </template>

        <template x-if="data">
          <FileList />
        </template>

        <template x-if="loading">
          <p class="text-center text-neutral-500 py-4">Caricamento...</p>
        </template>
      </div>
    </div>
  </div>

  <script>
    import Alpine from "alpinejs";
    import magicFilesPage from "@/alpine/magicFilesPage";

    document.addEventListener("alpine:init", () => {
      magicFilesPage(Alpine);
    });
  </script>
</BaseLayout>
