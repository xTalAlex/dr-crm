---
import AdminLayout from "@/layouts/AdminLayout.astro";
import PageHeader from "@/components/PageHeader.astro";
import { Icon } from "astro-icon/components";
import { getDb } from "@/lib/db";

export const prerender = false;

const user = Astro.locals.user;

let customerCount = 0;
try {
  customerCount = await getDb().customer.count();
} catch {
  console.error("DB Connection error: Unable to fetch customer count");
}

const links = [
  {
    label: "Gestione Clienti",
    desc: "Aggiungi, modifica, elimina",
    href: "/admin/customers",
    icon: "material-symbols-light:group-outline",
  },
  {
    label: "Documenti",
    desc: "Gestisci e invia documenti ai clienti",
    href: "/admin/files",
    icon: "material-symbols-light:description-outline",
  },
];
---

<AdminLayout title="Dashboard">
  <PageHeader
    title={`Ciao, ${user?.name?.split(" ")[0] ?? "Admin"}`}
    subtitle="Ecco un riepilogo della tua attività"
  />

  <!-- Stats -->
  <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-5 mb-10">
    <div
      class="bg-neutral-50 border border-neutral-200 rounded-xl p-5 flex items-center gap-4"
    >
      <div
        class="w-10 h-10 rounded-lg bg-petrol-50 border border-petrol-200 flex items-center justify-center"
      >
        <Icon
          name="material-symbols-light:group-outline"
          class="w-5 h-5 text-petrol-500"
        />
      </div>
      <div>
        <p class="text-2xl font-semibold text-neutral-900">{customerCount}</p>
        <p class="text-xs text-neutral-500">Clienti registrati</p>
      </div>
    </div>
  </div>

  <!-- Quick links -->
  <h2 class="text-xs text-neutral-900 uppercase tracking-wider mb-3">
    Azioni rapide
  </h2>
  <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-5">
    {
      links.map(({ label, desc, href, icon }) => (
        <a
          href={href}
          class="group bg-neutral-50 border border-neutral-200 hover:border-petrol-200 rounded-xl p-5 flex items-start gap-4 transition-colors"
        >
          <div class="w-10 h-10 rounded-lg bg-petrol-50 border border-petrol-200 flex items-center justify-center shrink-0">
            <Icon name={icon} class="w-5 h-5 text-petrol-500" />
          </div>
          <div>
            <p class="text-sm font-medium text-neutral-900 group-hover:text-petrol-500 transition-colors">
              {label}
            </p>
            <p class="text-xs text-neutral-500 mt-0.5">{desc}</p>
          </div>
        </a>
      ))
    }
  </div>
</AdminLayout>
