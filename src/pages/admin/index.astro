---
import AdminLayout from "@/layouts/AdminLayout.astro";
import PageHeader from "@/components/PageHeader.astro";
import SectionHeader from "@/components/SectionHeader.astro";
import WidgetCard from "@/components/WidgetCard.astro";
import { Icon } from "astro-icon/components";
import { getDb } from "@/lib/db";

export const prerender = false;

const user = Astro.locals.user;

let customerCount = 0;
try {
  customerCount = await getDb().customer.count();
} catch {
  console.error("DB Connection error: Unable to fetch customer count");
}

const links = [
  {
    label: "Gestione Pazienti",
    desc: "Aggiungi, modifica, elimina",
    href: "/admin/customers",
    icon: "material-symbols-light:group-outline",
  },
  {
    label: "Documenti",
    desc: "Gestisci e invia documenti ai pazienti",
    href: "/admin/files",
    icon: "material-symbols-light:files-outline",
  },
];
---

<AdminLayout title="Dashboard">
  <PageHeader
    title={`Ciao, ${user?.name?.split(" ")[0] ?? "Admin"}`}
    subtitle="Ecco un riepilogo della tua attività"
  />

  <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-5 mb-10">
    <WidgetCard icon="material-symbols-light:group-outline">
      <p class="text-2xl font-semibold text-neutral-900">{customerCount}</p>
      <p class="text-xs text-neutral-500">Pazienti registrati</p>
    </WidgetCard>
  </div>

  <section>
    <SectionHeader title="Azioni rapide" />
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-5">
      {
        links.map(({ label, desc, href, icon }) => (
          <WidgetCard {href} {icon}>
            <p class="text-sm font-medium text-neutral-900 group-hover:text-petrol-500 transition-colors">
              {label}
            </p>
            <p class="text-xs text-neutral-500 mt-0.5">{desc}</p>
          </WidgetCard>
        ))
      }
    </div>
  </section>
</AdminLayout>
