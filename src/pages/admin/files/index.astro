---
import AdminLayout from "@/layouts/AdminLayout.astro";
import PageHeader from "@/components/PageHeader.astro";
import SearchInput from "@/components/SearchInput.astro";
import DataTable from "@/components/DataTable.astro";
import Th from "@/components/Th.astro";
import Td from "@/components/Td.astro";
import IconButton from "@/components/IconButton.astro";
import Button from "@/components/Button.astro";
import FilesPageModals from "@/components/files/FilesPageModals.astro";
import Pagination from "@/components/Pagination.astro";
import { Icon } from "astro-icon/components";

export const prerender = false;
---

<AdminLayout title="Documenti">
  <div x-data="filesPage()" x-init="init()">
    <PageHeader
      title="Documenti"
      subtitle="Tutti i file caricati per i clienti"
    >
      <Button variant="outline" x-on:click="openUpload()">
        <Icon name="material-symbols-light:upload" class="size-4" />
        Carica documenti
      </Button>
    </PageHeader>

    <SearchInput
      placeholder="Cerca per etichetta, nome o cognome cliente..."
      x-model="search"
      x-on:input.debounce.300ms="page = 1; fetchData()"
    >
      <span
        x-show="search"
        x-cloak
        class="text-xs text-neutral-500 whitespace-nowrap"
        x-text="total + ' risultati'"></span>
    </SearchInput>

    <template x-if="loading">
      <p class="text-center text-neutral-500 py-8">Caricamento...</p>
    </template>

    <template x-if="!loading && groups.length === 0">
      <p class="text-center text-neutral-500 py-8">Nessun documento trovato</p>
    </template>

    <template x-if="!loading && groups.length > 0">
      <div>
        <DataTable>
          <thead>
            <tr class="border-b border-neutral-200 text-left">
              <Th>Etichetta</Th>
              <Th>Cliente</Th>
              <Th align="center">File</Th>
              <Th align="center">Dimensione</Th>
              <Th>Data</Th>
              <Th align="right">Azioni</Th>
            </tr>
          </thead>
          <tbody class="divide-y divide-neutral-100">
            <template x-for="g in groups" :key="g.id">
              <tr
                class="hover:bg-neutral-100 transition-colors cursor-pointer"
                x-on:click={`window.location.href = '/admin/customers/' + g.customer.id + '/files'`}
              >
                <Td class="font-medium" x-text="g.label || 'Senza nome'" />
                <Td x-text="customerLabel(g)" />
                <Td muted align="center">
                  <span x-text="g.files.length"></span>
                </Td>
                <Td muted align="center">
                  <span x-text="totalSize(g)"></span>
                </Td>
                <Td muted>
                  <span
                    x-text="new Date(g.createdAt).toLocaleDateString('it-IT')"
                  ></span>
                </Td>
                <Td align="right">
                  <div class="inline-flex gap-1">
                    <IconButton variant="amber" title="Gestisci file">
                      <Icon
                        name="material-symbols-light:folder-open-outline"
                        class="size-5"
                      />
                    </IconButton>
                  </div>
                </Td>
              </tr>
            </template>
          </tbody>
        </DataTable>

        <Pagination />
      </div>
    </template>

    <FilesPageModals />
  </div>

  <script>
    import Alpine from "alpinejs";
    import filesPage from "@/alpine/filesPage";

    document.addEventListener("alpine:init", () => {
      filesPage(Alpine);
    });
  </script>
</AdminLayout>
