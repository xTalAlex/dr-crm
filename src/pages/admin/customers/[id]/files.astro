---
import AdminLayout from "@/layouts/AdminLayout.astro";
import { Icon } from "astro-icon/components";

export const prerender = false;

const { id } = Astro.params;
---

<AdminLayout title="Documenti Cliente">
  <div x-data="customerFilesPage()" x-init="init()">
    <!-- Header -->
    <div class="flex items-center gap-3 mb-8">
      <a
        href="/admin/customers"
        class="p-1.5 text-gray-400 hover:text-petrol-700 transition-colors"
        title="Torna ai clienti"
      >
        <Icon name="material-symbols-light:arrow-back" class="w-5 h-5" />
      </a>
      <div>
        <h1 class="text-2xl font-serif text-slate-800">
          Documenti di <span x-text="customerName"></span>
        </h1>
        <p class="text-sm text-gray-400" x-text="customerPhone"></p>
      </div>
    </div>

    <!-- Upload section -->
    <div class="bg-white border border-gray-200 rounded-xl p-6 shadow-sm mb-8">
      <h2 class="text-sm font-medium text-slate-800 mb-4">Carica nuovi file</h2>
      <form x-on:submit.prevent="upload()" class="space-y-4">
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
          <div>
            <label
              class="block text-xs text-gray-400 uppercase tracking-wider mb-1.5"
            >
              Etichetta gruppo
            </label>
            <input
              type="text"
              x-model="uploadLabel"
              placeholder="es. Referti del 11/03/2026"
              class="w-full bg-gray-50 border border-gray-200 focus:border-petrol-400 rounded-lg px-3 py-2.5 text-slate-800 text-sm outline-none transition-colors"
            />
          </div>
          <div>
            <label
              class="block text-xs text-gray-400 uppercase tracking-wider mb-1.5"
            >
              File *
            </label>
            <input
              type="file"
              x-ref="fileInput"
              multiple
              class="w-full bg-gray-50 border border-gray-200 rounded-lg px-3 py-2 text-slate-800 text-sm file:mr-3 file:px-3 file:py-1 file:rounded-md file:border-0 file:bg-petrol-50 file:text-petrol-700 file:text-xs file:font-medium file:cursor-pointer"
            />
          </div>
        </div>
        <template x-if="uploadError">
          <p class="text-red-500 text-sm" x-text="uploadError"></p>
        </template>
        <div class="flex justify-end">
          <button
            type="submit"
            :disabled="uploading"
            class="inline-flex items-center gap-2 px-5 py-2.5 bg-petrol-600 hover:bg-petrol-700 text-white rounded-lg text-sm font-medium transition-all duration-300 disabled:opacity-50"
          >
            <Icon name="material-symbols-light:upload" class="w-4 h-4" />
            <span x-show="!uploading">Carica</span>
            <span x-show="uploading" x-cloak>Caricamento...</span>
          </button>
        </div>
      </form>
    </div>

    <!-- Loading -->
    <template x-if="loading">
      <p class="text-center text-gray-400 py-8">Caricamento...</p>
    </template>

    <!-- Empty state -->
    <template x-if="!loading && groups.length === 0">
      <p class="text-center text-gray-400 py-8">Nessun documento caricato</p>
    </template>

    <!-- File groups -->
    <div class="space-y-6">
      <template x-for="g in groups" :key="g.id">
        <div
          class="bg-white border border-gray-200 rounded-xl shadow-sm overflow-hidden"
        >
          <!-- Group header -->
          <div
            class="flex items-center justify-between px-5 py-4 border-b border-gray-100"
          >
            <div>
              <h3
                class="text-sm font-medium text-slate-800"
                x-text="g.label || 'Senza etichetta'"
              >
              </h3>
              <p class="text-xs text-gray-400 mt-0.5">
                <span x-text="g.files.length"></span> file &middot;
                <span x-text="new Date(g.createdAt).toLocaleDateString('it-IT')"
                ></span>
              </p>
            </div>
            <div class="flex items-center gap-1">
              <button
                x-on:click="openAddFiles(g)"
                class="p-1.5 text-gray-400 hover:text-petrol-700 transition-colors"
                title="Aggiungi file"
              >
                <Icon name="material-symbols-light:add" class="w-4 h-4" />
              </button>
              <button
                x-on:click="generateMagicLink(g)"
                class="p-1.5 text-gray-400 hover:text-petrol-700 transition-colors"
                title="Genera magic link"
              >
                <Icon name="material-symbols-light:link" class="w-4 h-4" />
              </button>
              <button
                x-on:click="confirmDeleteGroup(g)"
                class="p-1.5 text-gray-400 hover:text-red-500 transition-colors"
                title="Elimina gruppo"
              >
                <Icon
                  name="material-symbols-light:delete-outline"
                  class="w-4 h-4"
                />
              </button>
            </div>
          </div>

          <!-- Add files inline form -->
          <template x-if="addFilesGroupId === g.id">
            <div class="px-5 py-3 bg-petrol-50/30 border-b border-gray-100">
              <div class="flex items-center gap-3">
                <input
                  type="file"
                  x-ref="addFileInput"
                  multiple
                  class="flex-1 bg-white border border-gray-200 rounded-lg px-3 py-1.5 text-sm file:mr-3 file:px-3 file:py-1 file:rounded-md file:border-0 file:bg-petrol-50 file:text-petrol-700 file:text-xs file:font-medium file:cursor-pointer"
                />
                <button
                  x-on:click="doAddFiles(g.id)"
                  :disabled="addFilesUploading"
                  class="inline-flex items-center gap-1.5 px-3 py-1.5 bg-petrol-600 hover:bg-petrol-700 text-white text-xs rounded-lg font-medium transition-colors disabled:opacity-50"
                >
                  <Icon
                    name="material-symbols-light:upload"
                    class="w-3.5 h-3.5"
                  />
                  <span x-show="!addFilesUploading">Carica</span>
                  <span x-show="addFilesUploading" x-cloak>...</span>
                </button>
                <button
                  x-on:click="addFilesGroupId = null"
                  class="p-1.5 text-gray-400 hover:text-slate-800 transition-colors"
                  title="Annulla"
                >
                  <Icon name="material-symbols-light:close" class="w-4 h-4" />
                </button>
              </div>
              <template x-if="addFilesError">
                <p class="text-red-500 text-xs mt-2" x-text="addFilesError"></p>
              </template>
            </div>
          </template>

          <!-- Files list -->
          <ul class="divide-y divide-gray-100">
            <template x-for="f in g.files" :key="f.id">
              <li class="flex items-center justify-between px-5 py-3">
                <div class="min-w-0 flex-1">
                  <p
                    class="text-sm text-slate-800 truncate"
                    x-text="f.fileName"
                  >
                  </p>
                  <p
                    class="text-xs text-gray-400"
                    x-text="(f.size / 1024).toFixed(0) + ' KB — ' + f.mimeType"
                  >
                  </p>
                </div>
                <button
                  x-on:click="deleteFile(g, f)"
                  class="ml-3 p-1.5 text-gray-400 hover:text-red-500 transition-colors"
                  title="Elimina file"
                >
                  <Icon name="material-symbols-light:close" class="w-4 h-4" />
                </button>
              </li>
            </template>
          </ul>

          <!-- Magic link -->
          <template x-if="g.magicLink">
            <div
              class="px-5 py-3 bg-gray-50 border-t border-gray-100 space-y-2"
            >
              <div class="flex items-center gap-2">
                <Icon
                  name="material-symbols-light:link"
                  class="w-4 h-4 text-gray-400 shrink-0"
                />
                <input
                  type="text"
                  :value="magicLinkUrl(g.magicLink.token)"
                  readonly
                  class="flex-1 bg-white border border-gray-200 rounded px-2 py-1 text-xs text-gray-500 outline-none cursor-text"
                  x-on:click="$el.select()"
                />
                <button
                  x-on:click="copyLink(g.magicLink.token)"
                  class="px-2 py-1 text-xs text-petrol-700 hover:text-petrol-900 transition-colors shrink-0"
                  title="Copia">Copia</button
                >
                <span
                  class="text-xs shrink-0"
                  :class="new Date(g.magicLink.expiresAt) < new Date() ? 'text-red-400' : 'text-gray-400'"
                  x-text="new Date(g.magicLink.expiresAt) < new Date() ? 'Scaduto' : 'Scade ' + new Date(g.magicLink.expiresAt).toLocaleDateString('it-IT')"
                ></span>
              </div>
              <div class="flex items-center gap-2" x-data="{ showPin: false }">
                <span class="text-xs text-gray-400">PIN:</span>
                <span
                  class="font-mono font-medium text-sm text-slate-600"
                  x-text="showPin ? g.magicLink.pin : '••••'"></span>
                <button
                  x-on:click="showPin = !showPin"
                  class="text-xs text-gray-400 hover:text-petrol-700 transition-colors"
                  x-text="showPin ? 'Nascondi' : 'Mostra'"></button>
                <span class="mx-1 text-gray-200">|</span>
                <a
                  :href="waLinkForGroup(g)"
                  target="_blank"
                  rel="noopener noreferrer"
                  class="inline-flex items-center gap-1.5 px-2.5 py-1 bg-green-600 hover:bg-green-700 text-white text-xs rounded-md transition-colors"
                >
                  <Icon
                    name="material-symbols-light:chat-outline"
                    class="w-3.5 h-3.5"
                  />
                  WhatsApp
                </a>
                <button
                  x-on:click="sendSmsForGroup(g)"
                  class="inline-flex items-center gap-1.5 px-2.5 py-1 bg-blue-500 hover:bg-blue-600 text-white text-xs rounded-md transition-colors"
                >
                  <Icon
                    name="material-symbols-light:sms-outline"
                    class="w-3.5 h-3.5"
                  />
                  SMS
                </button>
              </div>
            </div>
          </template>
        </div>
      </template>
    </div>

    <!-- Delete group confirmation -->
    <div
      x-show="deleteGroupTarget"
      x-cloak
      class="fixed inset-0 z-50 flex items-center justify-center p-4"
    >
      <div
        class="absolute inset-0 bg-black/40"
        x-on:click="deleteGroupTarget = null"
      >
      </div>
      <div
        class="relative bg-white border border-gray-200 rounded-xl w-full max-w-sm p-6 text-center shadow-lg"
      >
        <p class="text-slate-800 mb-1">Eliminare questo gruppo?</p>
        <p
          class="text-gray-500 text-sm mb-6"
          x-text="deleteGroupTarget?.label || 'Senza etichetta'"
        >
        </p>
        <div class="flex justify-center gap-3">
          <button
            x-on:click="deleteGroupTarget = null"
            class="px-4 py-2.5 text-sm text-gray-500 hover:text-slate-800 transition-colors"
            >Annulla</button
          >
          <button
            x-on:click="doDeleteGroup()"
            :disabled="deleting"
            class="px-5 py-2.5 bg-red-50 hover:bg-red-100 border border-red-200 hover:border-red-300 text-red-600 rounded-lg text-sm font-medium transition-all duration-300 disabled:opacity-50"
            >Elimina</button
          >
        </div>
      </div>
    </div>

    <!-- Magic link modal -->
    <div
      x-show="magicLinkModal"
      x-cloak
      class="fixed inset-0 z-50 flex items-center justify-center p-4"
    >
      <div
        class="absolute inset-0 bg-black/40"
        x-on:click="magicLinkModal = false"
      >
      </div>
      <div
        class="relative bg-white border border-gray-200 rounded-xl w-full max-w-sm p-6 shadow-lg"
      >
        <h2 class="text-lg font-serif text-slate-800 mb-4">
          Genera Magic Link
        </h2>
        <template x-if="hasExistingLink">
          <div class="mb-4 p-3 bg-amber-50 border border-amber-200 rounded-lg">
            <p class="text-xs text-amber-700">
              Questo gruppo ha già un magic link attivo. Generandone uno nuovo,
              il precedente verrà invalidato.
            </p>
          </div>
        </template>
        <div class="mb-4">
          <label
            class="block text-xs text-gray-400 uppercase tracking-wider mb-1.5"
          >
            Scadenza (ore)
          </label>
          <input
            type="number"
            x-model.number="magicLinkHours"
            min="1"
            max="720"
            class="w-full bg-gray-50 border border-gray-200 focus:border-petrol-400 rounded-lg px-3 py-2.5 text-slate-800 text-sm outline-none transition-colors"
          />
        </div>
        <template x-if="magicLinkResult">
          <div class="mb-4 p-3 bg-green-50 border border-green-200 rounded-lg">
            <p class="text-xs text-green-700 mb-1">
              Link generato e copiato negli appunti!
            </p>
            <input
              type="text"
              :value="magicLinkUrl(magicLinkResult)"
              readonly
              class="w-full bg-white border border-green-200 rounded px-2 py-1 text-xs text-green-800 outline-none"
              x-on:click="$el.select()"
            />
            <p class="text-xs text-green-700 mt-3 mb-1">
              Codice PIN di accesso:
            </p>
            <p
              class="text-2xl font-mono font-bold text-green-800 tracking-widest"
              x-text="magicLinkPin"
            >
            </p>
            <p class="text-xs text-gray-400 mt-1">
              Comunica questo codice al cliente separatamente.
            </p>
            <div class="flex gap-2 mt-3">
              <a
                :href="waLinkWithMagic()"
                target="_blank"
                rel="noopener noreferrer"
                class="inline-flex items-center gap-1.5 px-3 py-1.5 bg-green-600 hover:bg-green-700 text-white text-xs rounded-lg transition-colors"
              >
                <Icon
                  name="material-symbols-light:chat-outline"
                  class="w-3.5 h-3.5"
                />
                WhatsApp
              </a>
              <button
                x-on:click="openSmsFromMagicLink()"
                class="inline-flex items-center gap-1.5 px-3 py-1.5 bg-blue-500 hover:bg-blue-600 text-white text-xs rounded-lg transition-colors"
              >
                <Icon
                  name="material-symbols-light:sms-outline"
                  class="w-3.5 h-3.5"
                />
                SMS
              </button>
            </div>
          </div>
        </template>
        <div class="flex justify-end gap-3">
          <button
            x-on:click="magicLinkModal = false; magicLinkResult = null; magicLinkPin = '';"
            class="px-4 py-2.5 text-sm text-gray-500 hover:text-slate-800 transition-colors"
            >Chiudi</button
          >
          <button
            x-show="!magicLinkResult"
            x-on:click="doGenerateMagicLink()"
            :disabled="generatingLink"
            class="px-5 py-2.5 bg-petrol-600 hover:bg-petrol-700 text-white rounded-lg text-sm font-medium transition-all duration-300 disabled:opacity-50"
          >
            <span x-show="!generatingLink">Genera</span>
            <span x-show="generatingLink" x-cloak>Generazione...</span>
          </button>
        </div>
      </div>
    </div>
  </div>

  <script define:vars={{ customerId: id }}>
    window.__customerId = customerId;
  </script>
  <script>
    import Alpine from "alpinejs";
    import customerFilesPage from "@/alpine/customerFilesPage";

    document.addEventListener("alpine:init", () => {
      customerFilesPage(Alpine);
    });
  </script>
</AdminLayout>
