---
import AdminLayout from "@/layouts/AdminLayout.astro";
import { Icon } from "astro-icon/components";

export const prerender = false;
---

<AdminLayout title="Clienti">
  <div x-data="customersPage()" x-init="fetchCustomers()">
    <!-- Header -->
    <div
      class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4 mb-8"
    >
      <h1 class="text-2xl font-serif text-slate-800">Clienti</h1>
      <button
        x-on:click="openCreate()"
        class="inline-flex items-center gap-2 bg-petrol-50 hover:bg-petrol-100 border border-petrol-200 hover:border-petrol-300 text-petrol-700 px-4 py-2.5 rounded-lg text-sm font-medium transition-all duration-300"
      >
        <Icon name="material-symbols-light:add" class="w-4 h-4" />
        Nuovo Cliente
      </button>
    </div>

    <!-- Search -->
    <div class="mb-6">
      <input
        type="text"
        x-model="search"
        x-on:input.debounce.300ms="page = 1; fetchCustomers()"
        placeholder="Cerca per nome, cognome, telefono, email..."
        class="w-full sm:max-w-md bg-gray-50 border border-gray-200 focus:border-petrol-400 rounded-lg px-4 py-2.5 text-slate-800 text-sm outline-none transition-colors placeholder:text-gray-400"
      />
    </div>

    <!-- Layout: Alphabet sidebar + Table -->
    <div class="flex gap-4">
      <!-- Alphabet sidebar -->
      <div
        class="hidden sm:flex flex-col gap-0.5 shrink-0 sticky top-20 self-start"
      >
        <button
          x-on:click="activeLetter = ''; page = 1; fetchCustomers()"
          :class="activeLetter === '' ? 'bg-petrol-50 text-petrol-700 border-petrol-200' : 'text-gray-400 hover:text-petrol-700 border-transparent hover:border-gray-200'"
          class="w-auto px-2 h-7 text-xs font-medium rounded border transition-all duration-200 flex items-center justify-center gap-1"
          >Tutti</button
        >
        <template x-for="l in Object.keys(letterCounts).sort()" :key="l">
          <button
            x-on:click="activeLetter = l; page = 1; fetchCustomers()"
            :class="activeLetter === l ? 'bg-petrol-50 text-petrol-700 border-petrol-200' : 'text-gray-400 hover:text-petrol-700 border-transparent hover:border-gray-200'"
            class="w-auto px-2 h-7 text-xs font-medium rounded border transition-all duration-200 flex items-center justify-center gap-1"
          >
            <span x-text="l"></span>
            <span class="text-[10px] opacity-60" x-text="letterCounts[l]"
            ></span>
          </button>
        </template>
      </div>

      <!-- Mobile letter filter -->
      <div
        class="sm:hidden flex flex-wrap gap-1 mb-4 -mt-2"
        x-show="showMobileLetters"
      >
        <button
          x-on:click="activeLetter = ''; page = 1; fetchCustomers()"
          :class="activeLetter === '' ? 'bg-petrol-50 text-petrol-700 border-petrol-200' : 'text-gray-400 border-gray-200'"
          class="px-2 py-1 text-xs rounded border transition-colors"
          >Tutti</button
        >
        <template x-for="l in Object.keys(letterCounts).sort()" :key="l">
          <button
            x-on:click="activeLetter = l; page = 1; fetchCustomers()"
            :class="activeLetter === l ? 'bg-petrol-50 text-petrol-700 border-petrol-200' : 'text-gray-400 border-gray-200'"
            class="px-2 py-1 text-xs rounded border transition-colors"
          >
            <span x-text="l"></span>
            <span class="text-[10px] opacity-60" x-text="letterCounts[l]"
            ></span>
          </button>
        </template>
      </div>

      <!-- Table + Pagination -->
      <div class="flex-1 min-w-0">
        <div
          class="bg-white border border-gray-200 rounded-xl overflow-hidden shadow-sm"
        >
          <!-- Mobile letter toggle -->
          <div class="sm:hidden px-4 pt-3">
            <button
              x-on:click="showMobileLetters = !showMobileLetters"
              class="text-xs text-gray-400 hover:text-petrol-700 transition-colors"
              x-text="showMobileLetters ? 'Nascondi rubrica' : 'Filtra per lettera'"
            ></button>
          </div>

          <div class="overflow-x-auto">
            <table class="w-full text-sm">
              <thead>
                <tr class="border-b border-gray-200 text-left">
                  <th
                    class="px-4 py-3 text-xs text-gray-400 uppercase tracking-wider font-medium"
                  >
                    Cognome
                  </th>
                  <th
                    class="px-4 py-3 text-xs text-gray-400 uppercase tracking-wider font-medium"
                  >
                    Nome
                  </th>
                  <th
                    class="px-4 py-3 text-xs text-gray-400 uppercase tracking-wider font-medium"
                    >Telefono</th
                  >
                  <th
                    class="px-4 py-3 text-xs text-gray-400 uppercase tracking-wider font-medium hidden md:table-cell"
                    >Email</th
                  >
                  <th
                    class="px-4 py-3 text-xs text-gray-400 uppercase tracking-wider font-medium hidden lg:table-cell"
                    >Codice Fiscale</th
                  >
                  <th
                    class="px-4 py-3 text-xs text-gray-400 uppercase tracking-wider font-medium text-right"
                    >Azioni</th
                  >
                </tr>
              </thead>
              <tbody>
                <template x-if="loading && customers.length === 0">
                  <tr
                    ><td colspan="6" class="px-4 py-8 text-center text-gray-400"
                      >Caricamento...</td
                    ></tr
                  >
                </template>
                <template x-if="!loading && customers.length === 0">
                  <tr
                    ><td colspan="6" class="px-4 py-8 text-center text-gray-400"
                      >Nessun cliente trovato</td
                    ></tr
                  >
                </template>
                <template x-for="c in customers" :key="c.id">
                  <tr
                    x-on:click="openEdit(c)"
                    class="border-b border-gray-100 hover:bg-gray-50 transition-colors cursor-pointer"
                  >
                    <td
                      class="px-4 py-3 text-slate-800 font-medium"
                      x-text="c.surname || '-'"></td>
                    <td class="px-4 py-3 text-slate-800" x-text="c.name"></td>
                    <td class="px-4 py-3 text-gray-500" x-text="c.phone"></td>
                    <td
                      class="px-4 py-3 text-gray-500 hidden md:table-cell"
                      x-text="c.email || '-'"></td>
                    <td
                      class="px-4 py-3 text-gray-500 hidden lg:table-cell"
                      x-text="c.fiscalCode || '-'"></td>
                    <td class="px-4 py-3 text-right" x-on:click.stop>
                      <div class="inline-flex gap-1">
                        <a
                          :href="'https://wa.me/' + c.phone.replace(/[^0-9+]/g, '')"
                          target="_blank"
                          rel="noopener noreferrer"
                          class="p-1.5 text-gray-400 hover:text-green-600 transition-colors"
                          title="WhatsApp"
                          x-on:click.stop
                        >
                          <Icon
                            name="material-symbols-light:chat-outline"
                            class="w-4 h-4"
                          />
                        </a>
                        <button
                          x-on:click="openSms(c)"
                          class="p-1.5 text-gray-400 hover:text-blue-500 transition-colors"
                          title="Invia SMS"
                        >
                          <Icon
                            name="material-symbols-light:sms-outline"
                            class="w-4 h-4"
                          />
                        </button>
                        <a
                          :href="'/admin/customers/' + c.id + '/files'"
                          class="p-1.5 text-gray-400 hover:text-petrol-700 transition-colors"
                          title="Documenti"
                          x-on:click.stop
                        >
                          <Icon
                            name="material-symbols-light:folder-outline"
                            class="w-4 h-4"
                          />
                        </a>
                        <button
                          x-on:click="openEdit(c)"
                          class="p-1.5 text-gray-400 hover:text-petrol-700 transition-colors"
                          title="Modifica"
                        >
                          <Icon
                            name="material-symbols-light:edit-outline"
                            class="w-4 h-4"
                          />
                        </button>
                        <button
                          x-on:click="confirmDelete(c)"
                          class="p-1.5 text-gray-400 hover:text-red-500 transition-colors"
                          title="Elimina"
                        >
                          <Icon
                            name="material-symbols-light:delete-outline"
                            class="w-4 h-4"
                          />
                        </button>
                      </div>
                    </td>
                  </tr>
                </template>
              </tbody>
            </table>
          </div>

          <!-- Pagination -->
          <div
            x-show="totalPages > 1"
            class="flex items-center justify-between px-4 py-3 border-t border-gray-200"
          >
            <p class="text-xs text-gray-400">
              <span x-text="total"></span> clienti totali
            </p>
            <div class="flex gap-1">
              <button
                x-on:click="page = 1; fetchCustomers()"
                :disabled="page <= 1"
                class="px-2.5 py-1.5 text-xs rounded-md border border-gray-200 text-gray-400 hover:text-petrol-700 hover:border-petrol-200 transition-colors disabled:opacity-30 disabled:pointer-events-none"
                title="Prima pagina">&laquo;</button
              >
              <button
                x-on:click="page > 1 && (page--, fetchCustomers())"
                :disabled="page <= 1"
                class="px-3 py-1.5 text-xs rounded-md border border-gray-200 text-gray-400 hover:text-petrol-700 hover:border-petrol-200 transition-colors disabled:opacity-30 disabled:pointer-events-none"
                >&larr;</button
              >
              <span
                class="px-3 py-1.5 text-xs text-gray-400"
                x-text="`${page} / ${totalPages}`"></span>
              <button
                x-on:click="page < totalPages && (page++, fetchCustomers())"
                :disabled="page >= totalPages"
                class="px-3 py-1.5 text-xs rounded-md border border-gray-200 text-gray-400 hover:text-petrol-700 hover:border-petrol-200 transition-colors disabled:opacity-30 disabled:pointer-events-none"
                >&rarr;</button
              >
              <button
                x-on:click="page = totalPages; fetchCustomers()"
                :disabled="page >= totalPages"
                class="px-2.5 py-1.5 text-xs rounded-md border border-gray-200 text-gray-400 hover:text-petrol-700 hover:border-petrol-200 transition-colors disabled:opacity-30 disabled:pointer-events-none"
                title="Ultima pagina">&raquo;</button
              >
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- Modal -->
    <div
      x-show="modal"
      x-cloak
      class="fixed inset-0 z-50 flex items-center justify-center p-4"
    >
      <div class="absolute inset-0 bg-black/40" x-on:click="modal = false">
      </div>
      <div
        class="relative bg-white border border-gray-200 rounded-xl w-full max-w-lg max-h-[90vh] overflow-y-auto p-6 shadow-lg"
      >
        <h2
          class="text-lg font-serif text-slate-800 mb-6"
          x-text="editing ? 'Modifica Cliente' : 'Nuovo Cliente'"
        >
        </h2>

        <form x-on:submit.prevent="save()" class="space-y-4">
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
            <div>
              <label
                class="block text-xs text-gray-400 uppercase tracking-wider mb-1.5"
                >Cognome</label
              >
              <input
                type="text"
                x-model="form.surname"
                x-ref="firstField"
                class="w-full bg-gray-50 border border-gray-200 focus:border-petrol-400 rounded-lg px-3 py-2.5 text-slate-800 text-sm outline-none transition-colors"
              />
            </div>
            <div>
              <label
                class="block text-xs text-gray-400 uppercase tracking-wider mb-1.5"
                >Nome</label
              >
              <input
                type="text"
                x-model="form.name"
                class="w-full bg-gray-50 border border-gray-200 focus:border-petrol-400 rounded-lg px-3 py-2.5 text-slate-800 text-sm outline-none transition-colors"
              />
            </div>
          </div>

          <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
            <div>
              <label
                class="block text-xs text-gray-400 uppercase tracking-wider mb-1.5"
                >Telefono *</label
              >
              <input
                type="tel"
                x-model="form.phone"
                required
                class="w-full bg-gray-50 border border-gray-200 focus:border-petrol-400 rounded-lg px-3 py-2.5 text-slate-800 text-sm outline-none transition-colors"
              />
            </div>
            <div>
              <label
                class="block text-xs text-gray-400 uppercase tracking-wider mb-1.5"
                >Telefono 2</label
              >
              <input
                type="tel"
                x-model="form.phone2"
                class="w-full bg-gray-50 border border-gray-200 focus:border-petrol-400 rounded-lg px-3 py-2.5 text-slate-800 text-sm outline-none transition-colors"
              />
            </div>
          </div>

          <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
            <div>
              <label
                class="block text-xs text-gray-400 uppercase tracking-wider mb-1.5"
                >Email</label
              >
              <input
                type="email"
                x-model="form.email"
                class="w-full bg-gray-50 border border-gray-200 focus:border-petrol-400 rounded-lg px-3 py-2.5 text-slate-800 text-sm outline-none transition-colors"
              />
            </div>
            <div>
              <label
                class="block text-xs text-gray-400 uppercase tracking-wider mb-1.5"
                >Codice Fiscale</label
              >
              <input
                type="text"
                x-model="form.fiscalCode"
                class="w-full bg-gray-50 border border-gray-200 focus:border-petrol-400 rounded-lg px-3 py-2.5 text-slate-800 text-sm outline-none transition-colors"
              />
            </div>
          </div>

          <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
            <div>
              <label
                class="block text-xs text-gray-400 uppercase tracking-wider mb-1.5"
                >Data di Nascita</label
              >
              <input
                type="date"
                x-model="form.birthDate"
                class="w-full bg-gray-50 border border-gray-200 focus:border-petrol-400 rounded-lg px-3 py-2.5 text-slate-800 text-sm outline-none transition-colors"
              />
            </div>
          </div>

          <div>
            <label
              class="block text-xs text-gray-400 uppercase tracking-wider mb-1.5"
              >Indirizzo</label
            >
            <input
              type="text"
              x-model="form.address"
              class="w-full bg-gray-50 border border-gray-200 focus:border-petrol-400 rounded-lg px-3 py-2.5 text-slate-800 text-sm outline-none transition-colors"
            />
          </div>

          <div>
            <label
              class="block text-xs text-gray-400 uppercase tracking-wider mb-1.5"
              >Note</label
            >
            <textarea
              x-model="form.notes"
              rows="3"
              class="w-full bg-gray-50 border border-gray-200 focus:border-petrol-400 rounded-lg px-3 py-2.5 text-slate-800 text-sm outline-none transition-colors resize-none"
            ></textarea>
          </div>

          <template x-if="formError">
            <p class="text-red-500 text-sm" x-text="formError"></p>
          </template>

          <div class="flex justify-end gap-3 pt-2">
            <button
              type="button"
              x-on:click="modal = false"
              class="px-4 py-2.5 text-sm text-gray-500 hover:text-slate-800 transition-colors"
              >Annulla</button
            >
            <button
              x-show="!editing"
              type="button"
              x-on:click="save(true)"
              :disabled="saving"
              class="px-5 py-2.5 bg-gray-50 hover:bg-gray-100 border border-gray-200 hover:border-gray-300 text-gray-600 rounded-lg text-sm font-medium transition-all duration-300 disabled:opacity-50"
            >
              <span x-show="!saving">Crea e continua</span>
              <span x-show="saving" x-cloak>Salvataggio...</span>
            </button>
            <button
              type="submit"
              :disabled="saving"
              class="px-5 py-2.5 bg-petrol-600 hover:bg-petrol-700 text-white rounded-lg text-sm font-medium transition-all duration-300 disabled:opacity-50"
            >
              <span x-show="!saving" x-text="editing ? 'Salva' : 'Crea'"></span>
              <span x-show="saving" x-cloak>Salvataggio...</span>
            </button>
          </div>
        </form>
      </div>
    </div>

    <!-- Delete confirmation -->
    <div
      x-show="deleteTarget"
      x-cloak
      class="fixed inset-0 z-50 flex items-center justify-center p-4"
    >
      <div
        class="absolute inset-0 bg-black/40"
        x-on:click="deleteTarget = null"
      >
      </div>
      <div
        class="relative bg-white border border-gray-200 rounded-xl w-full max-w-sm p-6 text-center shadow-lg"
      >
        <p class="text-slate-800 mb-1">Eliminare questo cliente?</p>
        <p
          class="text-gray-500 text-sm mb-6"
          x-text="(deleteTarget?.surname ? deleteTarget.surname + ' ' : '') + (deleteTarget?.name || '')"
        >
        </p>
        <div class="flex justify-center gap-3">
          <button
            x-on:click="deleteTarget = null"
            class="px-4 py-2.5 text-sm text-gray-500 hover:text-slate-800 transition-colors"
            >Annulla</button
          >
          <button
            x-on:click="doDelete()"
            :disabled="saving"
            class="px-5 py-2.5 bg-red-50 hover:bg-red-100 border border-red-200 hover:border-red-300 text-red-600 rounded-lg text-sm font-medium transition-all duration-300 disabled:opacity-50"
            >Elimina</button
          >
        </div>
      </div>
    </div>

    <!-- SMS Modal -->
    <div
      x-show="smsModal"
      x-cloak
      class="fixed inset-0 z-50 flex items-center justify-center p-4"
    >
      <div class="absolute inset-0 bg-black/40" x-on:click="smsModal = false">
      </div>
      <div
        class="relative bg-white border border-gray-200 rounded-xl w-full max-w-lg p-6 shadow-lg"
      >
        <h2 class="text-lg font-serif text-slate-800 mb-1">Invia SMS</h2>
        <p
          class="text-sm text-gray-400 mb-6"
          x-text="smsTarget ? (smsTarget.surname || '') + ' ' + (smsTarget.name || '') + ' — ' + smsTarget.phone : ''"
        >
        </p>

        <form x-on:submit.prevent="sendSms()" class="space-y-4">
          <div>
            <label
              class="block text-xs text-gray-400 uppercase tracking-wider mb-1.5"
              >Messaggio *</label
            >
            <textarea
              x-model="smsText"
              x-ref="smsField"
              required
              rows="4"
              maxlength="1600"
              class="w-full bg-gray-50 border border-gray-200 focus:border-petrol-400 rounded-lg px-3 py-2.5 text-slate-800 text-sm outline-none transition-colors resize-none"
            ></textarea>
            <p class="text-xs text-gray-400 mt-1 text-right">
              <span x-text="smsText.length"></span> / 1600
            </p>
          </div>

          <template x-if="smsError">
            <p class="text-red-500 text-sm" x-text="smsError"></p>
          </template>
          <template x-if="smsSuccess">
            <p class="text-green-600 text-sm" x-text="smsSuccess"></p>
          </template>

          <div class="flex justify-end gap-3 pt-2">
            <button
              type="button"
              x-on:click="smsModal = false"
              class="px-4 py-2.5 text-sm text-gray-500 hover:text-slate-800 transition-colors"
              >Annulla</button
            >
            <button
              type="submit"
              :disabled="smsSending"
              class="px-5 py-2.5 bg-petrol-600 hover:bg-petrol-700 text-white rounded-lg text-sm font-medium transition-all duration-300 disabled:opacity-50"
            >
              <span x-show="!smsSending">Invia</span>
              <span x-show="smsSending" x-cloak>Invio...</span>
            </button>
          </div>
        </form>
      </div>
    </div>
  </div>

  <script>
    import Alpine from "alpinejs";
    import customersPage from "@/alpine/customersPage";

    document.addEventListener("alpine:init", () => {
      customersPage(Alpine);
    });
  </script>
</AdminLayout>
