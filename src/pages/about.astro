---
import BaseLayout from "@/layouts/BaseLayout.astro";
import Navbar from "@/components/Navbar.astro";
import Footer from "@/components/Footer.astro";
import Hero from "@/components/about/Hero.astro";
import BiographySection from "@/components/about/BiographySection.astro";
import CTASection from "@/components/about/CTASection.astro";
import content from "@/data/content.json";

export const prerender = false;

const { doctor } = content;
---

<BaseLayout
  title={`${doctor.title} ${doctor.firstName} ${doctor.lastName} — Dentista a Varese`}
  description={`${doctor.title} ${doctor.firstName} ${doctor.lastName}, dentista a Varese dal 1984. Medico Chirurgo e Odontoiatra. Laureato all'Università di Pavia, missione umanitaria in Africa.`}
  noindex={false}
>
  <Navbar />

  <main class="pb-16">
    <Hero />
    <BiographySection />
    <CTASection />
  </main>

  <Footer />
</BaseLayout>
