---
import Modal from "@/components/Modal.astro";
import Button from "@/components/Button.astro";
import FormField from "@/components/FormField.astro";
import { Icon } from "astro-icon/components";
---

<Modal show="uploadModal" close="uploadModal = false" size="md">
  <h2 class="text-lg font-serif text-neutral-900 mb-4">Carica documenti</h2>

  <div class="space-y-4">
    <!-- Customer search -->
    <div>
      <label class="block text-sm font-medium text-neutral-700 mb-1">
        Cliente <span class="text-red-400">*</span>
      </label>

      <!-- Selected customer chip -->
      <template x-if="selectedCustomer">
        <div
          class="flex items-center gap-2 px-3 py-2 bg-petrol-50 border border-petrol-200 rounded-lg"
        >
          <Icon
            name="material-symbols-light:person-outline"
            class="w-4 h-4 text-petrol-500"
          />
          <span
            class="text-sm text-petrol-700 font-medium flex-1"
            x-text="customerDisplayName(selectedCustomer)"></span>
          <button
            type="button"
            x-on:click="clearCustomer()"
            class="p-0.5 text-petrol-400 hover:text-petrol-700 transition-colors"
          >
            <Icon name="material-symbols-light:close" class="w-4 h-4" />
          </button>
        </div>
      </template>

      <!-- Search input -->
      <template x-if="!selectedCustomer">
        <div class="relative">
          <input
            type="text"
            x-model="customerSearch"
            x-on:input.debounce.300ms="searchCustomers()"
            placeholder="Cerca per nome, cognome o telefono..."
            class="w-full bg-neutral-50 border border-neutral-200 focus:border-petrol-400 rounded-lg px-3 py-2 text-sm text-neutral-900 outline-none transition-colors"
          />
          <template x-if="searchingCustomers">
            <div
              class="absolute right-3 top-1/2 -translate-y-1/2 text-neutral-400"
            >
              <Icon
                name="material-symbols-light:progress-activity"
                class="w-4 h-4 animate-spin"
              />
            </div>
          </template>

          <!-- Results dropdown -->
          <template x-if="customerResults.length > 0">
            <ul
              class="absolute z-10 left-0 right-0 mt-1 bg-neutral-50 border border-neutral-200 rounded-lg shadow-lg max-h-48 overflow-y-auto"
            >
              <template x-for="c in customerResults" :key="c.id">
                <li>
                  <button
                    type="button"
                    x-on:click="selectCustomer(c)"
                    class="w-full text-left px-3 py-2 text-sm hover:bg-petrol-50 transition-colors flex items-center gap-2"
                  >
                    <span
                      class="font-medium text-neutral-900"
                      x-text="customerDisplayName(c)"></span>
                    <span
                      class="text-xs text-neutral-500"
                      x-text="c.phone || ''"></span>
                  </button>
                </li>
              </template>
            </ul>
          </template>

          <!-- No results -->
          <template
            x-if="customerSearch.length >= 2 && !searchingCustomers && customerResults.length === 0"
          >
            <p
              class="absolute z-10 left-0 right-0 mt-1 px-3 py-2 bg-neutral-50 border border-neutral-200 rounded-lg text-xs text-neutral-500"
            >
              Nessun cliente trovato
            </p>
          </template>
        </div>
      </template>
    </div>

    <FormField
      label="Nome cartella"
      x-model="uploadLabel"
      placeholder="es. Referti, Fatture, Radiografie..."
    />

    <div>
      <label class="block text-sm font-medium text-neutral-700 mb-1">
        File <span class="text-red-400">*</span>
      </label>
      <input
        type="file"
        x-ref="filesPageInput"
        multiple
        class="w-full bg-neutral-50 border border-neutral-200 rounded-lg px-3 py-1.5 text-sm file:mr-3 file:px-3 file:py-1 file:rounded-md file:border-0 file:bg-petrol-50 file:text-petrol-700 file:text-xs file:font-medium file:cursor-pointer"
      />
    </div>

    <template x-if="uploadError">
      <p class="text-red-500 text-sm" x-text="uploadError"></p>
    </template>
  </div>

  <div class="flex justify-end gap-3 pt-4">
    <button
      x-on:click="uploadModal = false"
      class="px-4 py-2.5 text-sm text-neutral-500 hover:text-neutral-900 transition-colors"
      >Annulla</button
    >
    <Button variant="primary" x-on:click="upload()" :disabled="uploading">
      <span x-show="!uploading">Carica</span>
      <span x-show="uploading" x-cloak>Caricamento...</span>
    </Button>
  </div>
</Modal>
