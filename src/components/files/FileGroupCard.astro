---
import Button from "@/components/Button.astro";
import IconButton from "@/components/IconButton.astro";
import Link from "@/components/Link.astro";
import FileGroupCardHeader from "@/components/files/FileGroupCardHeader.astro";
import FileGroupCardFooter from "@/components/files/FileGroupCardFooter.astro";
import { Icon } from "astro-icon/components";
---

<div class="bg-neutral-50 border border-neutral-200 rounded-xl shadow-sm">
  <FileGroupCardHeader />

  <!-- Add files inline form -->
  <template x-if="addFilesGroupId === g.id">
    <div class="px-5 py-3 bg-neutral-100">
      <div class="flex items-center gap-3">
        <input
          type="file"
          x-ref="addFileInput"
          multiple
          class="min-w-0 flex-1 bg-neutral-50 border border-neutral-200 rounded-lg px-3 py-1.5 text-sm file:mr-3 file:px-3 file:py-1 file:rounded-md file:border-0 file:bg-petrol-50 file:text-petrol-700 file:text-xs file:font-medium file:cursor-pointer"
        />
        <div class="flex items-center gap-2 shrink-0">
          <Button
            variant="primary"
            size="sm"
            x-on:click="doAddFiles(g.id)"
            :disabled="addFilesUploading"
          >
            <span x-show="!addFilesUploading">Carica</span>
            <span x-show="addFilesUploading" x-cloak>...</span>
          </Button>
          <IconButton x-on:click="addFilesGroupId = null" title="Chiudi">
            <Icon
              is:inline
              name="material-symbols-light:close"
              class="size-4"
            />
          </IconButton>
        </div>
      </div>
      <template x-if="addFilesError">
        <p class="text-red-500 text-xs mt-2" x-text="addFilesError"></p>
      </template>
    </div>
  </template>

  <!-- Files list -->
  <ul class="divide-y divide-neutral-100">
    <template x-for="f in g.files" :key="f.id">
      <li class="flex items-center justify-between px-5 py-3">
        <div class="min-w-0 flex-1">
          <Link
            :href="`/admin/api/customers/${customerId}/files/entries/${f.id}`"
            target="_blank"
            rel="noopener noreferrer"
            class="text-sm truncate inline-block max-w-full"
            x-text="f.fileName"
          />
          <p
            class="text-xs text-neutral-500"
            x-text="(f.size / 1024).toFixed(0) + ' KB · ' + new Date(f.createdAt).toLocaleString('it-IT')"
          >
          </p>
        </div>
        <IconButton
          variant="danger"
          x-on:click="confirmDeleteFile(g, f)"
          title="Elimina file"
          class="ml-3"
        >
          <Icon
            is:inline
            name="material-symbols-light:delete-outline"
            class="size-4"
          />
        </IconButton>
      </li>
    </template>
  </ul>

  <FileGroupCardFooter />
</div>
