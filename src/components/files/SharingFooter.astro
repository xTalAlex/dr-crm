---
import { Icon } from "astro-icon/components";
---

<!-- With magic link -->
<template x-if="g.magicLink">
  <div
    class="px-5 py-3 border-t border-neutral-200 bg-neutral-100/80"
    x-data="{ showPin: false, copied: false }"
  >
    <div
      class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-3"
    >
      <div class="flex items-center gap-3 flex-wrap">
        <button
          x-on:click="copyLink(g.magicLink.token); copied = true; setTimeout(() => copied = false, 2000)"
          class="inline-flex items-center justify-center gap-1.5 px-3 py-1.5 text-xs font-medium border rounded-lg transition-colors min-w-[6.5rem]"
          :class="copied ? 'border-green-300 text-green-600 bg-green-50' : 'border-neutral-200 hover:border-petrol-300 text-neutral-600 hover:text-petrol-700'"
        >
          <Icon
            is:inline
            x-show="!copied"
            name="material-symbols-light:content-copy"
            class="w-3.5 h-3.5"
          />
          <Icon
            is:inline
            x-show="copied"
            name="material-symbols-light:check"
            class="w-3.5 h-3.5"
            x-cloak
          />
          <span x-text="copied ? 'Copiato!' : 'Copia link'"></span>
        </button>
        <div
          class="inline-flex items-center gap-1.5 px-3 py-1.5 text-xs font-medium border border-neutral-200 text-neutral-600 rounded-lg"
        >
          <span class="text-xs text-neutral-500">PIN:</span>
          <span
            class="font-mono font-medium text-xs text-neutral-700"
            x-text="showPin ? g.magicLink.pin : '••••'"></span>
          <button
            x-on:click="showPin = !showPin"
            class="p-0.5 text-neutral-400 hover:text-petrol-700 transition-colors"
          >
            <Icon
              is:inline
              x-show="!showPin"
              name="material-symbols-light:visibility-outline"
              class="w-3.5 h-3.5"
            />
            <Icon
              is:inline
              x-show="showPin"
              name="material-symbols-light:visibility-off-outline"
              class="w-3.5 h-3.5"
              x-cloak
            />
          </button>
        </div>
        <p
          class="text-[10px]"
          :class="new Date(g.magicLink.expiresAt) < new Date() ? 'text-red-500' : 'text-neutral-500'"
          x-text="new Date(g.magicLink.expiresAt) < new Date()
            ? 'Scaduto il ' + new Date(g.magicLink.expiresAt).toLocaleString('it-IT')
            : 'Scade il ' + new Date(g.magicLink.expiresAt).toLocaleString('it-IT')"
        >
        </p>
      </div>
      <div class="flex flex-col sm:flex-row sm:items-center gap-2">
        <button
          x-on:click="generateMagicLink(g)"
          class="inline-flex items-center justify-center gap-1.5 px-3 py-1.5 text-xs font-medium border border-neutral-200 hover:border-petrol-300 text-neutral-600 hover:text-petrol-700 rounded-lg transition-colors"
        >
          <Icon
            is:inline
            name="material-symbols-light:link"
            class="w-3.5 h-3.5"
          />
          Genera link di condivisione
        </button>
        <button
          x-on:click="sendViaWhatsApp(g)"
          class="inline-flex items-center justify-center gap-1.5 px-3 py-1.5 text-xs font-medium bg-green-600 hover:bg-green-700 text-neutral-50 rounded-lg transition-colors shrink-0"
        >
          <Icon
            is:inline
            name="material-symbols-light:chat-outline"
            class="w-3.5 h-3.5"
          />
          Invia con WhatsApp
        </button>
      </div>
    </div>
  </div>
</template>

<!-- Without magic link -->
<template x-if="!g.magicLink">
  <div
    class="px-5 py-3 border-t border-neutral-200 bg-neutral-100/80 flex flex-col sm:flex-row sm:justify-end gap-2"
  >
    <button
      x-on:click="generateMagicLink(g)"
      class="inline-flex items-center gap-1.5 px-3 py-1.5 text-xs font-medium border border-neutral-200 hover:border-petrol-300 text-neutral-600 hover:text-petrol-700 rounded-lg transition-colors"
    >
      <Icon is:inline name="material-symbols-light:link" class="w-3.5 h-3.5" />
      Genera link di condivisione
    </button>
    <button
      x-on:click="sendViaWhatsApp(g)"
      class="inline-flex items-center gap-1.5 px-3 py-1.5 text-xs font-medium bg-green-600 hover:bg-green-700 text-neutral-50 rounded-lg transition-colors"
    >
      <Icon
        is:inline
        name="material-symbols-light:chat-outline"
        class="w-3.5 h-3.5"
      />
      Invia con WhatsApp
    </button>
  </div>
</template>
