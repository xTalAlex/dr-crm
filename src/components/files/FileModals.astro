---
import Modal from "@/components/Modal.astro";
import FormModal from "@/components/FormModal.astro";
import ConfirmModal from "@/components/ConfirmModal.astro";
import Alert from "@/components/Alert.astro";
import Button from "@/components/Button.astro";
import FormField from "@/components/FormField.astro";
---

<!-- Delete group confirmation -->
<ConfirmModal
  show="deleteTarget?.type === 'group'"
  close="deleteTarget = null"
  title="Eliminare questa cartella e tutti i suoi file?"
  description="deleteTarget?.group?.label || 'Senza nome'"
  confirm="doDelete()"
  confirmLabel="Elimina"
  disabled="deleting"
/>

<!-- Delete file confirmation -->
<ConfirmModal
  show="deleteTarget?.type === 'file'"
  close="deleteTarget = null"
  title="Eliminare questo file?"
  description="deleteTarget?.file?.fileName"
  confirm="doDelete()"
  confirmLabel="Elimina"
  disabled="deleting"
/>

<!-- Magic link modal -->
<Modal show="magicLinkModal" close="magicLinkModal = false" size="sm">
  <h2 class="text-lg font-serif text-neutral-900 mb-4">
    Genera link di condivisione
  </h2>
  <template x-if="hasExistingLink">
    <Alert class="mb-4">
      Questa cartella ha già un link attivo. Generandone uno nuovo, il
      precedente verrà invalidato.
    </Alert>
  </template>
  <FormField
    label="Scadenza (ore)"
    type="number"
    x-model.number="magicLinkHours"
    min="1"
    max="720"
    class="mb-4"
  />
  <div class="flex justify-end gap-3">
    <Button variant="ghost" x-on:click="magicLinkModal = false">Annulla</Button>
    <Button
      variant="primary"
      x-on:click="doGenerateMagicLink()"
      :disabled="generatingLink"
    >
      <span x-show="!generatingLink">Genera</span>
      <span x-show="generatingLink" x-cloak>Generazione...</span>
    </Button>
  </div>
</Modal>

<!-- Upload modal -->
<FormModal
  show="uploadModal"
  close="uploadModal = false"
  title="Carica file"
  action="upload()"
  actionLabel="Carica"
  disabled="uploading"
  loadingLabel="Caricamento..."
>
  <form x-on:submit.prevent="upload()" class="space-y-4">
    <FormField
      label="Nome cartella"
      x-model="uploadLabel"
      placeholder="es. Referti, Fatture, Radiografie..."
    />
    <FormField label="File" type="file" x-ref="fileInput" multiple required />
    <template x-if="uploadError">
      <p class="text-red-500 text-sm" x-text="uploadError"></p>
    </template>
  </form>
</FormModal>
