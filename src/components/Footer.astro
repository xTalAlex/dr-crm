---
import content from "@/data/content.json";
import CookieConsent from "@/components/CookieConsent.astro";

const { doctor, contacts } = content;
---

<footer class="border-t border-petrol-100 py-10">
  <div class="text-xs max-w-6xl mx-auto px-6 text-center">
    <p class="font-serif text-petrol-500 text-sm">
      {doctor.title}
      {doctor.firstName}
      {doctor.lastName}
    </p>
    <p class="mt-2">
      {doctor.roles.join(" — ")} — {contacts.address.city}
    </p>
    <p class="my-4">
      &copy; {new Date().getFullYear()} — Sviluppato da <a
        href="https://talale.it"
        target="_blank"
        rel="noopener noreferrer"
        class="hover:text-petrol-500 transition-colors">talale.it</a
      >
    </p>
    <CookieConsent />
  </div>
</footer>
