---
export interface Props {
  variant?: "amber" | "red" | "green";
  class?: string;
}

const { variant = "amber", class: className = "" } = Astro.props;
---

<div
  class:list={[
    "p-3 rounded-lg border text-xs",
    variant === "amber" && "bg-amber-50 border-amber-200 text-amber-600",
    variant === "red" && "bg-red-50 border-red-200 text-red-600",
    variant === "green" && "bg-green-50 border-green-200 text-green-600",
    className,
  ]}
>
  <slot />
</div>
