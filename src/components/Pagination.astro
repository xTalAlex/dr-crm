---

---

<template x-if="totalPages > 1">
  <div
    class="flex items-center justify-between mt-6 pt-4 border-t border-neutral-200"
  >
    <p class="text-xs text-neutral-500">
      Pagina <span x-text="page"></span> di <span x-text="totalPages"></span>
    </p>
    <div class="flex gap-2">
      <button
        x-on:click="page--; fetchData()"
        :disabled="page <= 1"
        class="px-3 py-1.5 border border-neutral-200 rounded-lg text-sm text-neutral-500 hover:text-petrol-700 hover:border-petrol-300 transition-colors disabled:opacity-30 disabled:cursor-not-allowed"
      >
        Precedente
      </button>
      <button
        x-on:click="page++; fetchData()"
        :disabled="page >= totalPages"
        class="px-3 py-1.5 border border-neutral-200 rounded-lg text-sm text-neutral-500 hover:text-petrol-700 hover:border-petrol-300 transition-colors disabled:opacity-30 disabled:cursor-not-allowed"
      >
        Successiva
      </button>
    </div>
  </div>
</template>
