---
import { Icon } from "astro-icon/components";
import content from "@/data/content.json";

const { doctor } = content;
const user = Astro.locals.user;
const currentPath = Astro.url.pathname;

const iconMap: Record<string, string> = {
  dashboard: "material-symbols-light:dashboard-outline",
  customers: "material-symbols-light:group-outline",
  documents: "material-symbols-light:description-outline",
};

const nav = [
  { label: "Dashboard", href: "/admin", icon: "dashboard" },
  { label: "Clienti", href: "/admin/customers", icon: "customers" },
  { label: "Documenti", href: "/admin/documents", icon: "documents" },
];
---

<aside
  x-cloak
  :class="sidebarOpen ? 'translate-x-0' : '-translate-x-full'"
  class="w-60 bg-neutral-50 border-r border-neutral-200 flex flex-col fixed inset-y-0 left-0 z-30 transition-transform duration-200 lg:translate-x-0"
>
  <div class="p-6 border-b border-neutral-200">
    <a href="/" class="font-serif text-petrol-500 text-lg tracking-wide"
      >{doctor.title} {doctor.lastName}</a
    >
    <p class="text-neutral-500 text-xs mt-1">Pannello Admin</p>
  </div>

  <nav class="flex-1 py-4 px-3 space-y-1">
    {
      nav.map(({ label, href, icon }) => {
        const active =
          currentPath === href ||
          (href !== "/admin" && currentPath.startsWith(href));
        return (
          <a
            href={href}
            x-on:click="sidebarOpen = false"
            class:list={[
              "flex items-center gap-3 px-3 py-2.5 rounded-lg text-sm transition-colors",
              active
                ? "bg-petrol-50 text-petrol-500 border border-petrol-200"
                : "text-neutral-500 hover:text-petrol-500 hover:bg-neutral-50",
            ]}
          >
            <Icon name={iconMap[icon]} class="w-5 h-5" />
            {label}
          </a>
        );
      })
    }
  </nav>

  <div class="p-4 border-t border-neutral-200">
    <div class="flex items-center gap-3 px-2">
      <div
        class="w-8 h-8 rounded-full bg-petrol-50 border border-petrol-200 flex items-center justify-center text-petrol-500 text-xs font-medium"
      >
        {user?.name?.[0]?.toUpperCase() ?? "A"}
      </div>
      <div class="min-w-0 flex-1">
        <p class="text-sm text-neutral-900 truncate">
          {user?.name ?? "Admin"}
        </p>
        <p class="text-xs text-neutral-500 truncate">{user?.email}</p>
      </div>
      <a
        href="/admin/settings"
        class:list={[
          "w-8 h-8 flex items-center justify-center rounded-lg transition-colors",
          currentPath.startsWith("/admin/settings")
            ? "text-petrol-500 bg-petrol-50"
            : "text-neutral-500 hover:text-petrol-500 hover:bg-neutral-50",
        ]}
        title="Impostazioni"
      >
        <Icon name="material-symbols-light:settings-outline" class="w-5 h-5" />
      </a>
    </div>
    <button
      id="logout-btn"
      class="w-full text-center px-3 py-2 mt-3 text-xs text-neutral-500 hover:text-red-500 transition-colors rounded-lg hover:bg-neutral-50"
    >
      Esci
    </button>
  </div>
</aside>
