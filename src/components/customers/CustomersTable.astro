---
import SearchInput from "@/components/SearchInput.astro";
import DataTable from "@/components/DataTable.astro";
import AlphabetFilter from "@/components/customers/AlphabetFilter.astro";
import EmptyState from "@/components/EmptyState.astro";
import LoadingState from "@/components/LoadingState.astro";
import Th from "@/components/Th.astro";
import Td from "@/components/Td.astro";
import IconButton from "@/components/IconButton.astro";
import Button from "@/components/Button.astro";
import TagChip from "@/components/TagChip.astro";
import { Icon } from "astro-icon/components";
---

<SearchInput
  placeholder="Cerca per nome, cognome, telefono, email..."
  x-model="search"
  x-on:input.debounce.300ms="activeLetter = ''; fetchCustomers()"
  x-on:search="activeLetter = ''; fetchCustomers()"
>
  <span
    x-show="search"
    x-cloak
    class="text-xs text-neutral-500 whitespace-nowrap"
    x-text="total + ' risultati'"></span>
</SearchInput>

<AlphabetFilter mode="mobile" />

<div class="flex gap-4">
  <AlphabetFilter mode="sidebar" />

  <!-- Table -->
  <div class="flex-1 min-w-0">
    <template x-if="loading && customers.length === 0">
      <LoadingState />
    </template>

    <template x-if="!loading && customers.length === 0">
      <EmptyState
        icon="material-symbols-light:group-outline"
        title="Nessun paziente trovato"
      >
        <Button
          variant="outline"
          size="xs"
          class="mt-3"
          x-show="search || activeLetter"
          x-cloak
          x-on:click="search = ''; activeLetter = ''; fetchCustomers()"
        >
          <Icon
            is:inline
            name="material-symbols-light:filter-alt-off-outline"
            class="size-3.5"
          />
          Rimuovi filtri
        </Button>
      </EmptyState>
    </template>

    <template x-if="customers.length > 0">
      <DataTable>
        <thead>
          <tr>
            <Th>Cognome</Th>
            <Th>Nome</Th>
            <Th>Telefono</Th>
            <Th>Tag</Th>
            <Th class="hidden md:table-cell">Note</Th>
            <Th align="right">Azioni</Th>
          </tr>
        </thead>
        <tbody>
          <template x-for="c in customers" :key="c.id">
            <tr x-on:click="openEdit(c)" class="cursor-pointer">
              <Td class="font-medium" x-text="c.surname || '-'" />
              <Td x-text="c.name" />
              <Td muted x-text="c.phone" />
              <Td>
                <div class="flex flex-col gap-1">
                  <template
                    x-for="ct in (c.tags ?? []).slice(0, 2)"
                    :key="ct.tag.id"
                  >
                    <TagChip :style="{ '--tag-color': ct.tag.color }">
                      <span x-text="ct.tag.name"></span>
                    </TagChip>
                  </template>
                  <span
                    x-show="(c.tags ?? []).length > 2"
                    class="w-fit text-xs font-medium tabular-nums text-petrol-500"
                    x-text="'+' + ((c.tags ?? []).length - 2)"></span>
                </div>
              </Td>
              <Td
                muted
                class="hidden md:table-cell text-xs max-w-50 truncate"
                x-text="c.notes || ''"
              />
              <Td align="right" x-on:click.stop>
                <div class="inline-flex gap-1">
                  <IconButton
                    as="a"
                    variant="green"
                    :href="waLink(c.phone)"
                    target="_blank"
                    rel="noopener noreferrer"
                    title="WhatsApp"
                    x-on:click.stop
                  >
                    <Icon
                      is:inline
                      name="material-symbols-light:chat-outline"
                      class="size-5"
                    />
                  </IconButton>
                  <IconButton
                    as="a"
                    variant="amber"
                    :href="'/admin/customers/' + c.id + '/files'"
                    title="Documenti"
                    x-on:click.stop
                  >
                    <Icon
                      is:inline
                      name="material-symbols-light:files-outline"
                      class="size-5"
                    />
                  </IconButton>
                  <IconButton
                    variant="danger"
                    x-on:click="confirmDelete(c)"
                    title="Elimina"
                  >
                    <Icon
                      is:inline
                      name="material-symbols-light:delete-outline"
                      class="size-4"
                    />
                  </IconButton>
                </div>
              </Td>
            </tr>
          </template>
        </tbody>
      </DataTable>
    </template>
  </div>
</div>
