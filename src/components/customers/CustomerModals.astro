---
import FormModal from "@/components/FormModal.astro";
import ConfirmModal from "@/components/ConfirmModal.astro";
import Button from "@/components/Button.astro";
import FormField from "@/components/FormField.astro";
import { Icon } from "astro-icon/components";
---

<FormModal
  show="modal"
  close="modal = false"
  size="lg"
  class="max-h-[90vh] overflow-y-auto"
  titleExpr="editing ? 'Modifica Cliente' : 'Nuovo Cliente'"
  action="save()"
  actionLabelExpr="editing ? 'Salva' : 'Crea'"
  disabled="saving"
  loadingLabel="Salvataggio..."
>
  <Button
    slot="extra-actions"
    variant="secondary"
    x-show="!editing"
    type="button"
    x-on:click="save(true)"
    :disabled="saving"
  >
    <span x-show="!saving">Crea e continua</span>
    <span x-show="saving" x-cloak>Salvataggio...</span>
  </Button>

  <form x-on:submit.prevent="save()" class="space-y-4">
    <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
      <FormField
        label="Cognome"
        x-model="form.surname"
        x-ref="firstField"
        required
        autocomplete="one-time-code"
      />
      <FormField
        label="Nome"
        x-model="form.name"
        autocomplete="one-time-code"
      />
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
      <FormField
        label="Telefono"
        type="tel"
        x-model="form.phone"
        required
        autocomplete="one-time-code"
      />
      <FormField
        label="Telefono 2"
        type="tel"
        x-model="form.phone2"
        autocomplete="one-time-code"
      />
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
      <FormField
        label="Email"
        type="email"
        x-model="form.email"
        autocomplete="one-time-code"
      />
    </div>

    <div>
      <button
        type="button"
        x-on:click="showExtra = !showExtra"
        class="flex items-center gap-1.5 text-xs text-neutral-500 hover:text-petrol-500 transition-colors select-none"
      >
        <Icon
          name="material-symbols-light:chevron-right"
          class="size-4 transition-transform"
          :class="showExtra ? 'rotate-90' : ''"
        />
        Dati aggiuntivi
      </button>

      <div x-show="showExtra" x-transition x-cloak class="mt-3 space-y-4">
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
          <FormField
            label="Codice Fiscale"
            x-model="form.fiscalCode"
            autocomplete="one-time-code"
          />
          <FormField
            label="Data di Nascita"
            type="date"
            x-model="form.birthDate"
            autocomplete="one-time-code"
          />
        </div>

        <FormField
          label="Indirizzo"
          x-model="form.address"
          autocomplete="one-time-code"
        />
      </div>
    </div>

    <FormField label="Note" type="textarea" x-model="form.notes" rows="3" />
  </form>

  <template x-if="formError">
    <p class="text-red-500 text-sm" x-text="formError"></p>
  </template>
</FormModal>

<ConfirmModal
  show="deleteTarget"
  close="deleteTarget = null"
  title="Eliminare questo cliente?"
  description="(deleteTarget?.surname ? deleteTarget.surname + ' ' : '') + (deleteTarget?.name || '')"
  confirm="doDelete()"
  confirmLabel="Elimina"
  disabled="saving"
/>
