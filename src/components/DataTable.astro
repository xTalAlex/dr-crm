---
interface Props {
  class?: string;
  [key: string]: any;
}

const { class: className = "", ...rest } = Astro.props;
---

<div
  class:list={[
    "bg-neutral-50 border border-neutral-200 rounded-xl overflow-hidden shadow-sm",
    className,
  ]}
  {...rest}
>
  <div class="overflow-x-auto">
    <table class="w-full text-sm">
      <slot />
    </table>
  </div>
</div>
