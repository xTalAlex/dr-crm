---
import { Icon } from "astro-icon/components";
import content from "@/data/content.json";

const { practice, contacts } = content;
---

<section id="contatti" class="py-24">
  <div class="max-w-6xl mx-auto px-6">
    <div class="text-center mb-16">
      <span
        class="text-petrol-600/60 text-xs tracking-[0.3em] uppercase font-medium"
        >Contatti</span
      >
      <h2 class="mt-4 font-serif text-3xl md:text-4xl text-slate-800">
        Contatti
      </h2>
      <div
        class="mt-4 h-px w-24 mx-auto bg-linear-to-r from-transparent via-petrol-500/30 to-transparent"
      >
      </div>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-6 max-w-4xl mx-auto">
      <!-- Phone -->
      <a
        href={`tel:${contacts.phone.href}`}
        class="group bg-white border border-gray-200 hover:border-petrol-300 rounded-xl p-8 text-center transition-all duration-300 shadow-sm hover:shadow-md"
      >
        <div
          class="w-12 h-12 mx-auto mb-4 rounded-full bg-petrol-50 flex items-center justify-center"
        >
          <Icon
            name="material-symbols-light:call-outline"
            class="w-5 h-5 text-petrol-700"
          />
        </div>
        <p class="text-xs text-gray-400 uppercase tracking-wider mb-2">
          Telefono
        </p>
        <p
          class="text-slate-800 group-hover:text-petrol-700 font-medium transition-colors"
        >
          {contacts.phone.display}
        </p>
        <p class="text-gray-400 text-xs mt-2">{contacts.phone.note}</p>
      </a>

      <!-- Email -->
      <a
        href={`mailto:${contacts.email}`}
        class="group bg-white border border-gray-200 hover:border-petrol-300 rounded-xl p-8 text-center transition-all duration-300 shadow-sm hover:shadow-md"
      >
        <div
          class="w-12 h-12 mx-auto mb-4 rounded-full bg-petrol-50 flex items-center justify-center"
        >
          <Icon
            name="material-symbols-light:mail-outline"
            class="w-5 h-5 text-petrol-700"
          />
        </div>
        <p class="text-xs text-gray-400 uppercase tracking-wider mb-2">Email</p>
        <p
          class="text-slate-800 group-hover:text-petrol-700 font-medium transition-colors text-sm"
        >
          {contacts.email}
        </p>
      </a>

      <!-- Address -->
      <a
        href={`https://maps.google.com/?q=${encodeURIComponent(contacts.address.street + " " + contacts.address.city)}`}
        target="_blank"
        rel="noopener noreferrer"
        class="group bg-white border border-gray-200 hover:border-petrol-300 rounded-xl p-8 text-center transition-all duration-300 shadow-sm hover:shadow-md"
      >
        <div
          class="w-12 h-12 mx-auto mb-4 rounded-full bg-petrol-50 flex items-center justify-center"
        >
          <Icon
            name="material-symbols-light:location-on-outline"
            class="w-5 h-5 text-petrol-700"
          />
        </div>
        <p class="text-xs text-gray-400 uppercase tracking-wider mb-2">
          Indirizzo
        </p>
        <p
          class="text-slate-800 group-hover:text-petrol-700 font-medium transition-colors"
        >
          {contacts.address.street}
        </p>
        <p class="text-gray-400 text-sm">{contacts.address.city}</p>
      </a>
    </div>

    <div class="mt-12 text-center">
      <p class="text-gray-400 text-sm italic">{practice.note}</p>
    </div>
  </div>
</section>
