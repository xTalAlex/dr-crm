---
import ContactCard from "@/components/home/ContactCard.astro";
import content from "@/data/content.json";

const { practice, contacts } = content;
---

<section id="contatti" class="py-24">
  <div class="max-w-6xl mx-auto px-6">
    <div class="text-center mb-16">
      <span
        class="text-petrol-500/50 text-xs tracking-[0.3em] uppercase font-medium"
        >Contatti</span
      >
      <h2 class="mt-4 font-serif text-3xl md:text-4xl text-neutral-900">
        Contatti
      </h2>
      <div
        class="mt-4 h-px w-24 mx-auto bg-linear-to-r from-transparent via-petrol-500/50 to-transparent"
      >
      </div>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-6 max-w-4xl mx-auto">
      <ContactCard
        href={`tel:${contacts.phone.href}`}
        icon="material-symbols-light:call-outline"
        label="Telefono"
        value={contacts.phone.display}
      >
        <p class="text-neutral-500 text-xs mt-2">{contacts.phone.note}</p>
      </ContactCard>

      <ContactCard
        href={`mailto:${contacts.email}`}
        icon="material-symbols-light:mail-outline"
        label="Email"
        value={contacts.email}
      />

      <ContactCard
        href={`https://maps.google.com/?q=${encodeURIComponent(contacts.address.street + " " + contacts.address.city)}`}
        icon="material-symbols-light:location-on-outline"
        label="Indirizzo"
        value={contacts.address.street}
        target="_blank"
        rel="noopener noreferrer"
      >
        <p class="text-neutral-500 text-sm">{contacts.address.city}</p>
      </ContactCard>
    </div>

    <div class="mt-12 text-center">
      <p class="text-petrol-500 text-sm italic">{practice.note}</p>
    </div>
  </div>
</section>
