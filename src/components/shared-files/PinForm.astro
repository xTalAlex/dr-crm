---
import Button from "@/components/Button.astro";
---

<form x-on:submit.prevent="verify()" class="space-y-5">
  <p class="text-sm text-neutral-500 text-center">
    Inserisci il codice PIN per accedere ai documenti
  </p>
  <div class="flex justify-center gap-3">
    <input
      type="text"
      inputmode="numeric"
      maxlength="1"
      x-ref="pin0"
      class="w-12 h-14 text-center text-2xl font-mono font-semibold bg-neutral-50 border-2 border-neutral-200 focus:border-petrol-500 rounded-xl text-neutral-900 outline-none transition-colors shadow-sm"
      x-on:input="$el.value = $el.value.replace(/[^0-9]/g, ''); pinDigits[0] = $el.value; pin = pinDigits.join(''); if ($el.value) $refs.pin1.focus()"
      x-on:keydown.backspace="if (!$el.value) { pinDigits[0] = ''; pin = pinDigits.join('') }"
      x-on:paste.prevent="const t = $event.clipboardData.getData('text').replace(/[^0-9]/g, '').slice(0,4); for (let j=0;j<4;j++) { pinDigits[j]=t[j]||''; if ($refs['pin'+j]) $refs['pin'+j].value=pinDigits[j]; } pin=pinDigits.join(''); if (t.length>0) $refs['pin'+Math.min(t.length-1,3)].focus(); if (pin.length===4) verify()"
    />
    <input
      type="text"
      inputmode="numeric"
      maxlength="1"
      x-ref="pin1"
      class="w-12 h-14 text-center text-2xl font-mono font-semibold bg-neutral-50 border-2 border-neutral-200 focus:border-petrol-500 rounded-xl text-neutral-900 outline-none transition-colors shadow-sm"
      x-on:input="$el.value = $el.value.replace(/[^0-9]/g, ''); pinDigits[1] = $el.value; pin = pinDigits.join(''); if ($el.value) $refs.pin2.focus()"
      x-on:keydown.backspace="if (!$el.value) { $refs.pin0.focus(); pinDigits[0] = ''; $refs.pin0.value = ''; pin = pinDigits.join('') }"
    />
    <input
      type="text"
      inputmode="numeric"
      maxlength="1"
      x-ref="pin2"
      class="w-12 h-14 text-center text-2xl font-mono font-semibold bg-neutral-50 border-2 border-neutral-200 focus:border-petrol-500 rounded-xl text-neutral-900 outline-none transition-colors shadow-sm"
      x-on:input="$el.value = $el.value.replace(/[^0-9]/g, ''); pinDigits[2] = $el.value; pin = pinDigits.join(''); if ($el.value) $refs.pin3.focus()"
      x-on:keydown.backspace="if (!$el.value) { $refs.pin1.focus(); pinDigits[1] = ''; $refs.pin1.value = ''; pin = pinDigits.join('') }"
    />
    <input
      type="text"
      inputmode="numeric"
      maxlength="1"
      x-ref="pin3"
      class="w-12 h-14 text-center text-2xl font-mono font-semibold bg-neutral-50 border-2 border-neutral-200 focus:border-petrol-500 rounded-xl text-neutral-900 outline-none transition-colors shadow-sm"
      x-on:input="$el.value = $el.value.replace(/[^0-9]/g, ''); pinDigits[3] = $el.value; pin = pinDigits.join(''); if (pin.length === 4) verify()"
      x-on:keydown.backspace="if (!$el.value) { $refs.pin2.focus(); pinDigits[2] = ''; $refs.pin2.value = ''; pin = pinDigits.join('') }"
    />
  </div>
  <template x-if="error">
    <p class="text-center text-red-500 text-sm" x-text="error"></p>
  </template>
  <div class="flex justify-center">
    <Button
      type="submit"
      :disabled="loading || pin.length < 4"
    >
      Accedi
    </Button>
  </div>
</form>
