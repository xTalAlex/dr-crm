---
import Button from "@/components/Button.astro";
---

<div>
  <h2
    class="text-lg font-serif text-neutral-900 mb-1"
    x-text="data.label || 'Documenti'"
  >
  </h2>
  <p class="text-xs text-neutral-500 mb-6">
    Questo link scade il <span
      x-text="new Date(data.expiresAt).toLocaleString('it-IT')"></span>
  </p>
  <ul class="space-y-2">
    <template x-for="f in data.files" :key="f.fileName">
      <li
        class="flex items-center justify-between p-3 bg-neutral-100 rounded-lg border border-neutral-200"
      >
        <div class="min-w-0 flex-1">
          <p class="text-sm text-neutral-900 truncate" x-text="f.fileName"></p>
          <p
            class="text-xs text-neutral-500"
            x-text="(f.size / 1024).toFixed(0) + ' KB'"
          >
          </p>
        </div>
        <Button
          as="a"
          size="sm"
          :href="f.url"
          target="_blank"
          rel="noopener noreferrer"
          class="ml-3"
        >
          Scarica
        </Button>
      </li>
    </template>
  </ul>
</div>
