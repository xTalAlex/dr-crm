---
import Wordmark from "@/components/Wordmark.astro";
import Button from "@/components/Button.astro";
import logo from "@/assets/images/logo.svg";
const user = Astro.locals.user;
---

<nav
  class="fixed top-0 w-full z-50 bg-neutral-50/80 backdrop-blur-md border-b border-neutral-200"
>
  <div class="max-w-6xl mx-auto px-6 py-4 flex items-center justify-between">
    <div class="flex items-center gap-3">
      <a href="/" class="inline-flex items-center gap-2">
        <img src={logo.src} alt="Logo" class="size-7" />
        <span class="pt-2 hidden sm:inline"><Wordmark class="text-lg" /></span>
      </a>
      {
        user?.role === "admin" ? (
          <span class="sm:hidden">
            <Button as="a" href="/admin" variant="outline" size="xs" pill>
              Admin
            </Button>
          </span>
        ) : (
          <span class="sm:hidden">
            <Button as="a" href="/auth/login" variant="ghost" size="xs">
              Login
            </Button>
          </span>
        )
      }
    </div>
    <div class="flex items-center gap-3 sm:gap-6 text-xs sm:text-sm">
      <a
        href="/about"
        class="text-neutral-500 hover:text-petrol-500 transition-colors"
        >Il Dottore</a
      >
      <a
        href="/#servizi"
        class="hidden sm:inline text-neutral-500 hover:text-petrol-500 transition-colors"
        >Servizi</a
      >
      <Button as="a" href="/#contatti" size="sm" pill> Contatti </Button>
      {
        user?.role === "admin" ? (
          <span class="hidden sm:inline-flex">
            <Button as="a" href="/admin" variant="outline" size="xs" pill>
              Admin
            </Button>
          </span>
        ) : (
          <span class="hidden sm:inline-flex">
            <Button as="a" href="/auth/login" variant="ghost" size="xs">
              Login
            </Button>
          </span>
        )
      }
    </div>
  </div>
</nav>
