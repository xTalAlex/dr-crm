---
import IconButton from "@/components/IconButton.astro";
import { Icon } from "astro-icon/components";

interface Props {
  label?: string;
  required?: boolean;
}

const { label = "Paziente", required = false } = Astro.props;
---

<div>
  <label class="block text-xs text-neutral-500 uppercase tracking-wider mb-1.5">
    {label}{required && <span class="text-red-500"> *</span>}
  </label>
  <!-- Selected customer chip -->
  <template x-if="selectedCustomer">
    <div
      class="flex items-center gap-2 px-3 py-2 bg-petrol-50 border border-petrol-200 rounded-lg"
    >
      <Icon
        is:inline
        name="material-symbols-light:person-outline"
        class="size-4 text-petrol-500"
      />
      <span
        class="text-sm text-petrol-700 font-medium flex-1"
        x-text="customerDisplayName(selectedCustomer)"></span>
      <IconButton x-on:click="clearCustomer()" title="Rimuovi">
        <Icon is:inline name="material-symbols-light:close" class="size-4" />
      </IconButton>
    </div>
  </template>

  <!-- Search input -->
  <template x-if="!selectedCustomer">
    <div class="relative">
      <input
        type="text"
        x-model="customerSearch"
        x-on:input.debounce.300ms="searchCustomers()"
        placeholder="Cerca per nome, cognome o telefono..."
        class="w-full bg-neutral-50 border border-neutral-200 focus:border-petrol-500 rounded-lg px-3 py-2.5 text-neutral-900 text-sm outline-none transition-colors"
      />
      <template x-if="searchingCustomers">
        <div class="absolute right-3 top-1/2 -translate-y-1/2 text-neutral-400">
          <Icon
            is:inline
            name="material-symbols-light:progress-activity"
            class="size-4 animate-spin"
          />
        </div>
      </template>

      <!-- Results dropdown -->
      <template x-if="customerResults.length > 0">
        <ul
          class="absolute z-10 inset-x-0 mt-1 bg-neutral-50 border border-neutral-200 rounded-lg shadow-lg max-h-48 overflow-y-auto"
        >
          <template x-for="c in customerResults" :key="c.id">
            <li>
              <button
                type="button"
                x-on:click="selectCustomer(c)"
                class="w-full text-left px-3 py-2 text-sm hover:bg-petrol-50 transition-colors flex items-center gap-2"
              >
                <span
                  class="font-medium text-neutral-900"
                  x-text="customerDisplayName(c)"></span>
                <span class="text-xs text-neutral-500" x-text="c.phone || ''"
                ></span>
              </button>
            </li>
          </template>
        </ul>
      </template>

      <!-- No results -->
      <template
        x-if="customerSearch.length >= 2 && !searchingCustomers && customerResults.length === 0"
      >
        <p
          class="absolute z-10 inset-x-0 mt-1 px-3 py-2 bg-neutral-50 border border-neutral-200 rounded-lg text-xs text-neutral-500"
        >
          Nessun paziente trovato
        </p>
      </template>
    </div>
  </template>
</div>
