---
interface Props {
  color?: string | null;
  name?: string;
  size?: "sm" | "md";
  class?: string;
  [key: string]: any;
}

const { color, name, size = "sm", class: className, ...attrs } = Astro.props;

const style = color ? `--tag-color: ${color}` : undefined;
const hasActions = Astro.slots.has("actions");
---

<span
  class:list={[
    "inline-flex items-center border gap-1 rounded-full font-medium",
    size === "sm" && "px-1.5 py-0.5 text-[10px] max-w-24",
    size === "md" && "px-3 py-1.5 text-sm",
    className,
  ]}
  style={`background: color-mix(in srgb, var(--tag-color, var(--color-petrol-500)) 15%, transparent); color: color-mix(in srgb, var(--tag-color, var(--color-petrol-500)), black 40%); border-color: color-mix(in srgb, var(--tag-color, var(--color-petrol-500)) 20%, transparent);${style ? ` ${style};` : ""}`}
  {...attrs}
>
  <span
    class:list={[
      "rounded-full shrink-0",
      size === "sm" ? "size-1.5" : "size-2.5",
    ]}
    style="background: var(--tag-color, var(--color-petrol-500))"></span>
  <span class="truncate">{name}<slot /></span>
  {hasActions && <slot name="actions" />}
</span>
