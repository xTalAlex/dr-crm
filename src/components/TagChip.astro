---
interface Props {
  color?: string | null;
  name?: string;
  size?: "sm" | "md";
  class?: string;
  [key: string]: any;
}

const { color, name, size = "sm", class: className, ...attrs } = Astro.props;

const tagColor = color || "var(--color-petrol-500)";
const hasActions = Astro.slots.has("actions");
---

<span
  class:list={[
    "inline-flex items-center border gap-1 rounded-full font-medium",
    /* bg, text, border derived from --tag-color */
    "bg-(--tag-color)/15 text-[color-mix(in_srgb,var(--tag-color),black_40%)] border-(--tag-color)/20",
    size === "sm" && "px-1.5 py-0.5 text-[10px] max-w-24",
    size === "md" && "px-3 py-1.5 text-sm",
    className,
  ]}
  style={`--tag-color: ${tagColor}`}
  {...attrs}
>
  <span
    class:list={[
      "bg-(--tag-color) rounded-full shrink-0",
      size === "sm" ? "size-1.5" : "size-2.5",
    ]}></span>
  <span class:list={["truncate", size === "sm" && "translate-y-0.5"]}
    >{name}<slot /></span
  >
  {hasActions && <slot name="actions" />}
</span>
