---
import { Icon } from "astro-icon/components";

interface Props {
  icon: string;
  href?: string;
}

const { icon, href } = Astro.props;
const Tag = href ? "a" : "div";
---

<Tag
  href={href}
  class:list={[
    "bg-neutral-50 border border-neutral-200 rounded-xl p-5 flex items-start gap-4",
    href && "group hover:border-petrol-200 transition-colors",
  ]}
>
  <div
    class="size-10 rounded-lg bg-petrol-50 border border-petrol-200 flex items-center justify-center shrink-0"
  >
    <Icon is:inline name={icon} class="size-5 text-petrol-500" />
  </div>
  <div>
    <slot />
  </div>
</Tag>
