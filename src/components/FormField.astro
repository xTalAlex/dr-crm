---
interface Props {
  label?: string;
  type?: string;
  class?: string;
  [key: string]: any;
}

const {
  label,
  type = "text",
  class: className = "",
  required,
  ...rest
} = Astro.props;

const isTextarea = type === "textarea";
const isFile = type === "file";
---

<div>
  {
    label && (
      <label class="block text-xs text-neutral-500 uppercase tracking-wider mb-1.5">
        {label}
        {required && <span class="text-red-500"> *</span>}
      </label>
    )
  }
  {
    isTextarea ? (
      <textarea
        class:list={[
          "w-full bg-neutral-50 border border-neutral-200 focus:border-petrol-500 rounded-lg px-3 py-2.5 text-neutral-900 text-sm outline-none transition-colors resize-none",
          className,
        ]}
        required={required}
        {...rest}
      />
    ) : (
      <input
        type={type}
        class:list={[
          isFile
            ? "w-full bg-neutral-50 border border-neutral-200 rounded-lg px-3 py-2 text-neutral-900 text-sm file:mr-3 file:px-3 file:py-1 file:rounded-md file:border-0 file:bg-petrol-50 file:text-petrol-700 file:text-xs file:font-medium file:cursor-pointer"
            : "w-full bg-neutral-50 border border-neutral-200 focus:border-petrol-500 rounded-lg px-3 py-2.5 text-neutral-900 text-sm outline-none transition-colors",
          className,
        ]}
        required={required}
        {...rest}
      />
    )
  }
</div>
