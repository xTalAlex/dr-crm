---
import { Icon } from "astro-icon/components";
import EmptyState from "@/components/EmptyState.astro";
import LoadingState from "@/components/LoadingState.astro";
import TagChip from "@/components/TagChip.astro";
import IconButton from "@/components/IconButton.astro";
---

<!-- Loading state -->
<template x-if="loading && tags.length === 0">
  <LoadingState />
</template>

<!-- Empty state -->
<template x-if="!loading && tags.length === 0">
  <EmptyState
    icon="material-symbols-light:label-outline"
    title="Nessun tag creato"
    description="Crea tag per categorizzare i tuoi pazienti"
  />
</template>

<!-- Tag chips grid -->
<div x-show="tags.length > 0" class="flex flex-wrap gap-2">
  <template x-for="tag in tags" :key="tag.id">
    <TagChip
      size="md"
      class="group transition-all duration-200 hover:shadow-sm"
      :style="{ '--tag-color': tag.color }"
    >
      <span x-text="tag.name"></span>
      <span
        class="text-xs opacity-50 tabular-nums select-none"
        x-text="tag._count?.customers ?? 0"></span>

      <div
        slot="actions"
        class="inline-flex items-center gap-0.5 ml-1 opacity-0 group-hover:opacity-100 transition-opacity"
      >
        <IconButton x-on:click.stop="openTagForm(tag)" title="Modifica">
          <Icon
            is:inline
            name="material-symbols-light:edit-outline"
            class="size-3.5"
          />
        </IconButton>
        <IconButton
          variant="danger"
          x-on:click.stop="confirmDeleteTag(tag)"
          title="Elimina"
        >
          <Icon
            is:inline
            name="material-symbols-light:close"
            class="size-3.5"
          />
        </IconButton>
      </div>
    </TagChip>
  </template>
</div>
