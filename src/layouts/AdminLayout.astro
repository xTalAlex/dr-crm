---
import BaseLayout from "@/layouts/BaseLayout.astro";
import AdminSidebar from "@/components/AdminSidebar.astro";
import { Icon } from "astro-icon/components";
import content from "@/data/content.json";

const { doctor } = content;

export const prerender = false;

interface Props {
  title: string;
}

const { title } = Astro.props;
---

<BaseLayout
  title={`${title} — CRM`}
  bodyClass="bg-neutral-50 text-neutral-900 font-sans antialiased min-h-screen"
  noindex
>
  <div x-data="{ sidebarOpen: false }">
    <!-- Mobile overlay -->
    <div
      x-show="sidebarOpen"
      x-cloak
      x-on:click="sidebarOpen = false"
      class="fixed inset-0 bg-neutral-900/40 z-20 lg:hidden"
    >
    </div>

    <AdminSidebar />

    <!-- Mobile header -->
    <header
      class="lg:hidden fixed top-0 left-0 right-0 z-10 bg-neutral-50/80 backdrop-blur-md border-b border-neutral-200 px-4 py-3 flex items-center justify-between"
    >
      <button
        x-on:click="sidebarOpen = true"
        class="text-neutral-500 hover:text-petrol-700"
      >
        <Icon name="material-symbols-light:menu" class="w-6 h-6" />
      </button>
      <span class="font-serif text-petrol-700 text-sm tracking-wide"
        >{doctor.title} {doctor.lastName}</span
      >
      <div class="w-6"></div>
    </header>

    <!-- Main content -->
    <main class="lg:ml-60 flex-1 min-h-screen pt-14 lg:pt-0">
      <div class="p-4 sm:p-6 lg:p-8">
        <slot />
      </div>
    </main>
  </div>

  <script>
    import { signOut } from "@/lib/auth-client";

    document
      .getElementById("logout-btn")
      ?.addEventListener("click", async () => {
        await signOut();
        window.location.href = "/auth/login";
      });
  </script>
</BaseLayout>
