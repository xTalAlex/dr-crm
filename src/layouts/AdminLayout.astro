---
import BaseLayout from "@/layouts/BaseLayout.astro";
import AdminSidebar from "@/components/AdminSidebar.astro";
import { Icon } from "astro-icon/components";
import Wordmark from "@/components/Wordmark.astro";

export const prerender = false;

export interface Props {
  title: string;
}

const { title } = Astro.props;
---

<BaseLayout title={`${title} — CRM`} bodyClass="min-h-screen" noindex>
  <div x-data="{ sidebarOpen: false }">
    <!-- Mobile overlay -->
    <div
      x-show="sidebarOpen"
      x-cloak
      x-on:click="sidebarOpen = false"
      class="fixed inset-0 bg-neutral-900/50 z-20 lg:hidden"
    >
    </div>

    <AdminSidebar />

    <!-- Mobile header -->
    <header
      class="lg:hidden fixed top-0 inset-x-0 z-10 bg-neutral-50 border-b border-neutral-200 px-4 py-3 flex items-center justify-between"
    >
      <button
        x-on:click="sidebarOpen = true"
        class="text-neutral-500 hover:text-petrol-500"
      >
        <Icon is:inline name="material-symbols-light:menu" class="size-6" />
      </button>
      <Wordmark class="text-sm" />
      <div class="w-6"></div>
    </header>

    <!-- Main content -->
    <main class="lg:ml-60 flex-1 min-h-screen pt-14 lg:pt-0">
      <div class="p-4 sm:p-6 lg:p-8">
        <slot />
      </div>
    </main>
  </div>
</BaseLayout>
